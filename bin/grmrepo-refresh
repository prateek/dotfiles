#!/usr/bin/env zsh
# Refresh the GRM (git-repo-manager) config from local canonical clones.
#
# Writes a per-machine-type fragment, not one shared config:
#   - machine_type=work  -> host-local ~/.config/grm/config.local.toml (never committed)
#   - otherwise          -> committed <source>/.chezmoiassets/grm/<machine_type>.toml
# Owners already listed in base.toml (shared across all machines) are skipped so they
# are never duplicated. After writing the fragment, the merged ~/.config/grm/config.toml
# that grm actually reads is re-rendered via `chezmoi apply`.
#
# This intentionally tracks canonical clones, not standard git worktrees.
# A canonical clone has a `.git/` directory (worktrees have a `.git` file).

set -euo pipefail
unsetopt xtrace 2>/dev/null || true
set +x 2>/dev/null || true

if ! command -v chezmoi >/dev/null 2>&1; then
  echo "grmrepo-refresh: chezmoi not found on PATH" >&2
  exit 127
fi

github_root="${GHPATH:-$HOME/code/github.com}"
github_root_tilde="${github_root/#$HOME/~}"

machine_type="$(chezmoi execute-template '{{ .machine_type }}' 2>/dev/null || true)"
[[ -n "$machine_type" ]] || machine_type="personal"

source_dir="$(chezmoi source-path 2>/dev/null || echo "$HOME/dotfiles/home")"
base_fragment="${source_dir}/.chezmoiassets/grm/base.toml"
merged_config="${GRMREPO_CONFIG:-$HOME/.config/grm/config.toml}"

# Route output by machine type: work stays host-local, everything else is committed.
if [[ "$machine_type" == "work" ]]; then
  target="$HOME/.config/grm/config.local.toml"
else
  target="${source_dir}/.chezmoiassets/grm/${machine_type}.toml"
fi

# Owners listed in base.toml are shared; skip them here so they are not duplicated.
typeset -A base_owners
if [[ -f "$base_fragment" ]]; then
  while IFS= read -r line; do
    case "$line" in
      ('root = '*github.com/*)
        owner="${line##*github.com/}"
        owner="${owner%\"}"
        [[ -n "$owner" ]] && base_owners[$owner]=1
        ;;
    esac
  done < "$base_fragment"
fi

tmp="$(mktemp "${TMPDIR:-/tmp}/grmrepo-config.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

_remote_type() {
  local url="$1"
  if [[ "$url" == http://* || "$url" == https://* ]]; then
    echo "https"
  else
    echo "ssh"
  fi
}

_write_repo_block() {
  local repo_name="$1"
  local repo_dir="$2"

  print -r -- "[[trees.repos]]"
  print -r -- "name = \"${repo_name}\""
  print -r -- "worktree_setup = false"
  print -r -- ""

  local -a remotes
  remotes=("${(@f)$(git -C "$repo_dir" remote 2>/dev/null || true)}")
  remotes=("${(@o)remotes}")

  local remote_name remote_url remote_type
  for remote_name in "${remotes[@]}"; do
    remote_url="$(git -C "$repo_dir" remote get-url "$remote_name" 2>/dev/null || true)"
    [[ -n "$remote_url" ]] || continue

    # Skip unsupported protocols (e.g. local filesystem remotes like /Users/me/repo).
    if [[ "$remote_url" != http://* && "$remote_url" != https://* && "$remote_url" != *:* && "$remote_url" != ssh://* ]]; then
      continue
    fi

    remote_type="$(_remote_type "$remote_url")"

    print -r -- "[[trees.repos.remotes]]"
    print -r -- "name = \"${remote_name}\""
    print -r -- "url = \"${remote_url}\""
    print -r -- "type = \"${remote_type}\""
    print -r -- ""
  done
}

{
  print -r -- "# Generated by grmrepo-refresh (machine_type=${machine_type})."
  print -r -- "# Per-machine-type fragment; merged with base.toml into ~/.config/grm/config.toml."
  print -r -- "# Canonical clone root:"
  print -r -- "#   - ${github_root_tilde}/<owner>/<repo>"
  print -r -- ""

  # IMPORTANT:
  # GRM splits repo names on the final `/` into (namespace, name), and `repos status`
  # currently uses only `name` when locating the repo path. To keep status working,
  # we emit one tree per namespace (GitHub owner), and keep `name` as just `<repo>`.
  if [[ -d "$github_root" ]]; then
    local owner_dir owner repo_dir repo_name
    for owner_dir in "$github_root"/*(N-/); do
      owner="${owner_dir:t}"

      # Owners covered by base.toml are shared across machines; do not duplicate them.
      [[ -z "${base_owners[$owner]:-}" ]] || continue

      local -a repos
      repos=()
      for repo_dir in "$owner_dir"/*(N-/); do
        [[ -d "$repo_dir/.git" ]] || continue
        repos+=("$repo_dir")
      done
      (( ${#repos[@]} > 0 )) || continue

      print -r -- "[[trees]]"
      print -r -- "root = \"${github_root_tilde}/${owner}\""
      print -r -- ""

      repos=("${(@o)repos}")
      for repo_dir in "${repos[@]}"; do
        repo_name="${repo_dir:t}"
        _write_repo_block "$repo_name" "$repo_dir"
      done
    done
  fi
} > "$tmp"

# Normalize to a single trailing newline so generated fragments stay diff-clean.
content="$(<"$tmp")"
printf '%s\n' "$content" >| "$tmp"

mkdir -p "$(dirname "$target")"
if [[ -f "$target" ]] && command -v cmp >/dev/null 2>&1 && cmp -s "$tmp" "$target"; then
  : # unchanged
else
  cat "$tmp" >| "$target"
  echo "Wrote: $target" >&2
fi

# Re-render the merged config grm actually reads (base + this machine's fragment).
chezmoi apply --force "$merged_config" >/dev/null 2>&1 || true
