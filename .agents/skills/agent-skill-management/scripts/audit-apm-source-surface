#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
from __future__ import annotations

import argparse
import sys
from pathlib import Path


UNSUPPORTED = {
    "hooks",
    "mcp",
    "mcpServers",
    "servers",
    "lsp",
    "monitors",
    "commands",
    "prompts",
}


def inside_skill_root(path: Path, root: Path) -> bool:
    current = path
    while current != root.parent:
        if (current / "SKILL.md").exists():
            return True
        if current == root:
            break
        current = current.parent
    return False


def component_boundary(path: Path, root: Path) -> bool:
    parts = path.relative_to(root).parts
    if len(parts) == 1:
        return True
    if len(parts) == 3:
        return True
    return len(parts) >= 2 and parts[-2] == ".apm"


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("source_audit_root")
    args = parser.parse_args()

    root = Path(args.source_audit_root)
    if not root.exists():
        print(f"audit-apm-source-surface: missing {root}", file=sys.stderr)
        return 1
    findings = []
    for path in root.rglob("*"):
        if (
            path.is_dir()
            and path.name in UNSUPPORTED
            and component_boundary(path, root)
            and not inside_skill_root(path, root)
        ):
            findings.append(str(path))
    if findings:
        for finding in findings:
            print(f"unsupported APM component: {finding}", file=sys.stderr)
        return 1
    print("OK audit-apm-source-surface")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
