#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
"""Print native CLI commands needed to reconcile the local plugin marketplace.

This is a preview-only helper: copy/paste the printed commands. There is no
apply path here; native Codex and Claude CLIs own the installed/cache state.
"""
from __future__ import annotations

from agent_skill_lib import load_packages


def main() -> int:
    # Codex picks plugins up purely from ~/.codex/config.toml (chezmoi-managed
    # marketplace + per-plugin tables). The current `codex plugin` CLI only
    # exposes a `marketplace` subcommand — there is no `codex plugin install`
    # or `codex plugin enable/disable` to mirror the Claude commands here.
    commands = [
        "claude plugin marketplace add ~/.agents/plugins --scope user",
        "claude plugin marketplace update prateek-local",
        "codex plugin marketplace upgrade prateek-local",
    ]
    for package in load_packages():
        if package.render.get("claude") != "plugin":
            continue
        slug = f"{package.package_id}@prateek-local"
        toggle = "enable" if package.default_loaded else "disable"
        commands.append(f"claude plugin install {slug} --scope user")
        commands.append(f"claude plugin {toggle} {slug} --scope user")
    for command in commands:
        print(command)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
