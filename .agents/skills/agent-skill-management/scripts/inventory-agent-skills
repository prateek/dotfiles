#!/usr/bin/env python3
from __future__ import annotations

import json
from pathlib import Path

from agent_skill_lib import (
    load_packages,
    skill_frontmatter,
)


def main() -> int:
    packages = load_packages()
    payload = {"packages": [], "generated": {}}
    seen: dict[str, list[str]] = {}
    for package in packages:
        skills = []
        for skill in package.skills:
            meta = skill_frontmatter(skill.path)
            seen.setdefault(skill.skill_id, []).append(str(skill.path))
            skills.append(
                {
                    "id": skill.skill_id,
                    "name": meta["name"],
                    "kind": skill.kind,
                    "path": str(skill.path),
                }
            )
        payload["packages"].append(
            {
                "id": package.package_id,
                "display_name": package.display_name,
                "render": package.render,
                "skills": skills,
            }
        )
    payload["duplicates"] = {
        skill_id: paths for skill_id, paths in sorted(seen.items()) if len(paths) > 1
    }
    home = Path.home()
    payload["live"] = {
        "codex_root_exists": (home / ".agents/skills").exists(),
        "claude_root_exists": (home / ".claude/skills").exists(),
        "plugins_root_exists": (home / ".agents/plugins").exists(),
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
