#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
from __future__ import annotations

import argparse
import shutil
import sys
import tempfile
from pathlib import Path

from agent_skill_lib import (
    CLAUDE_PLUGIN_SETTINGS_TEMPLATE,
    CODEX_PLUGIN_CONFIG_TEMPLATE,
    copy_skill_tree,
    load_packages,
    require_no_drift,
    require_file_text,
    reset_dir,
    write_text,
    write_generated_readme,
    write_json,
)


GENERATOR = ".agents/skills/agent-skill-management/scripts/render-agent-plugin-marketplace"
CODEX_PLUGIN_SOURCE_ROOT = "./.agents/plugins/plugins"

# Codex plugins consume skills and hooks; the remaining payload kinds are
# Claude-only until Codex grows an equivalent surface.
CODEX_UNMAPPED_PAYLOADS = {"commands", "agents", ".mcp.json"}


def codex_plugin_manifest(package) -> dict:
    return {
        "name": package.package_id,
        "version": "1.0.0",
        "description": f"{package.display_name} skills from Prateek's dotfiles.",
        "author": {"name": "Prateek"},
        "license": "UNLICENSED",
        "skills": "./skills/",
        "interface": {
            "displayName": package.display_name,
            "shortDescription": f"{package.display_name} skills",
            "longDescription": f"Generated local plugin for {package.display_name}.",
            "developerName": "Prateek",
            "category": "Coding",
            "capabilities": ["Interactive", "Write"],
            "defaultPrompt": [f"Use the {package.display_name} plugin."],
        },
    }


def claude_plugin_manifest(package) -> dict:
    return {
        "name": package.package_id,
        "version": "1.0.0",
        "description": f"{package.display_name} skills from Prateek's dotfiles.",
        "author": {"name": "Prateek"},
        "skills": ["./skills"],
    }


def copy_payloads(package, plugin_root: Path) -> None:
    # Payloads land at the plugin-spec conventional locations both agents
    # auto-discover; manifests only need the explicit skills key.
    for payload in package.payloads:
        source = package.path / payload
        if payload == "hooks.json":
            target = plugin_root / "hooks/hooks.json"
            target.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(source, target)
        elif payload == ".mcp.json":
            shutil.copy2(source, plugin_root / ".mcp.json")
        else:
            shutil.copytree(source, plugin_root / payload)
    if package.render.get("codex") == "plugin":
        for payload in package.payloads:
            if payload in CODEX_UNMAPPED_PAYLOADS:
                print(
                    f"warning: {package.package_id}: codex has no mapping for "
                    f"{payload}; that payload is claude-only",
                    file=sys.stderr,
                )


def render_plugins(target: Path, packages) -> None:
    reset_dir(target)
    write_generated_readme(target, GENERATOR)
    (target / "plugins").mkdir(parents=True, exist_ok=True)

    codex_marketplace = {
        "name": "prateek-local",
        "interface": {"displayName": "Prateek Local Plugins"},
        "plugins": [],
    }
    claude_marketplace = {
        "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
        "name": "prateek-local",
        "description": "Prateek local agent packages",
        "owner": {"name": "Prateek"},
        "plugins": [],
    }

    for package in packages:
        if "plugin" not in package.render.values():
            continue
        slug = package.package_id
        plugin_root = target / "plugins" / slug
        skills_root = plugin_root / "skills"
        skills_root.mkdir(parents=True, exist_ok=True)
        write_generated_readme(
            plugin_root,
            GENERATOR,
            f"Source package: `home/dot_agents/packages/{package.package_id}/`.",
        )
        if package.render.get("codex") == "plugin":
            write_json(plugin_root / ".codex-plugin/plugin.json", codex_plugin_manifest(package))
        if package.render.get("claude") == "plugin":
            write_json(plugin_root / ".claude-plugin/plugin.json", claude_plugin_manifest(package))
        for skill in package.skills:
            copy_skill_tree(skill.path, skills_root / skill.skill_id)
        copy_payloads(package, plugin_root)

        if package.render.get("codex") == "plugin":
            codex_marketplace["plugins"].append(
                {
                    "name": slug,
                    # Codex resolves marketplace local paths from the supported
                    # marketplace root, not from the marketplace.json directory.
                    "source": {
                        "source": "local",
                        "path": f"{CODEX_PLUGIN_SOURCE_ROOT}/{slug}",
                    },
                    "policy": {
                        "installation": "INSTALLED_BY_DEFAULT",
                        "authentication": "ON_INSTALL",
                    },
                    "category": "Productivity",
                }
            )
        if package.render.get("claude") == "plugin":
            claude_marketplace["plugins"].append(
                {
                    "name": slug,
                    "description": f"{package.display_name} skills from Prateek's dotfiles.",
                    "author": {"name": "Prateek"},
                    "category": "development",
                    "source": f"./plugins/{slug}",
                }
            )

    write_json(target / "marketplace.json", codex_marketplace)
    write_json(target / ".claude-plugin/marketplace.json", claude_marketplace)


def render_codex_config_template(path: Path, packages) -> None:
    lines = [
        "# Generated by .agents/skills/agent-skill-management/scripts/render-agent-plugin-marketplace.",
        "# Rerun the generator (without --skip-config-templates) after editing",
        "# home/dot_agents/packages/*/package.toml; chezmoi apply does not",
        "# regenerate this fragment.",
        "",
        "[marketplaces.prateek-local]",
        'source_type = "local"',
        'source = "{{ .chezmoi.homeDir }}/.agents/plugins"',
    ]
    for package in packages:
        if package.render.get("codex") != "plugin":
            continue
        lines.extend(
            [
                "",
                f'[plugins."{package.package_id}@prateek-local"]',
                f"enabled = {'true' if package.default_loaded else 'false'}",
            ]
        )
    write_text(path, "\n".join(lines) + "\n")


def render_claude_settings_template(path: Path, packages) -> None:
    enabled_plugins = {
        f"{package.package_id}@prateek-local": package.default_loaded
        for package in packages
        if package.render.get("claude") == "plugin"
    }
    settings = {
        "_generated": (
            "Generated by .agents/skills/agent-skill-management/scripts/"
            "render-agent-plugin-marketplace. Rerun the generator (without "
            "--skip-config-templates) after editing render policy in "
            "home/dot_agents/packages/*/package.toml; chezmoi apply does not "
            "regenerate this fragment."
        ),
        "extraKnownMarketplaces": {
            "prateek-local": {
                "source": {
                    "source": "directory",
                    "path": "{{ .chezmoi.homeDir }}/.agents/plugins",
                }
            }
        },
        "enabledPlugins": enabled_plugins,
    }
    write_json(path, settings)


def render_config_templates(codex_path: Path, claude_path: Path, packages) -> None:
    render_codex_config_template(codex_path, packages)
    render_claude_settings_template(claude_path, packages)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--plugins-root",
        type=Path,
        help="plugin marketplace output directory to render or check",
    )
    parser.add_argument("--check", action="store_true")
    parser.add_argument(
        "--skip-config-templates",
        action="store_true",
        help="render or check only the marketplace tree, not Codex/Claude templates",
    )
    args = parser.parse_args()
    packages = load_packages()
    plugins_root = args.plugins_root.expanduser() if args.plugins_root else None

    if plugins_root is None:
        parser.error("--plugins-root is required")

    if args.check:
        with tempfile.TemporaryDirectory() as tmp:
            tmp_path = Path(tmp)
            expected = tmp_path / "plugins"
            expected_codex = tmp_path / "agent-codex-plugin-config.toml.tmpl"
            expected_claude = tmp_path / "agent-claude-plugin-settings.json.tmpl"
            render_plugins(expected, packages)
            render_config_templates(expected_codex, expected_claude, packages)
            require_no_drift(expected, plugins_root, str(plugins_root))
            if not args.skip_config_templates:
                require_file_text(
                    expected_codex,
                    CODEX_PLUGIN_CONFIG_TEMPLATE,
                    "home/.chezmoitemplates/agent-codex-plugin-config.toml.tmpl",
                )
                require_file_text(
                    expected_claude,
                    CLAUDE_PLUGIN_SETTINGS_TEMPLATE,
                    "home/.chezmoitemplates/agent-claude-plugin-settings.json.tmpl",
                )
        return 0

    render_plugins(plugins_root, packages)
    if not args.skip_config_templates:
        render_config_templates(
            CODEX_PLUGIN_CONFIG_TEMPLATE,
            CLAUDE_PLUGIN_SETTINGS_TEMPLATE,
            packages,
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
