<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>iOS Audit — {{ audit.meta.app.name if audit.meta.app else 'Unknown' }}</title>
<style>
:root {
  --sev-critical: #b91c1c;
  --sev-major: #c2410c;
  --sev-moderate: #a16207;
  --sev-minor: #475569;
  --bg: #f8fafc;
  --card: #ffffff;
  --border: #e5e7eb;
  --ink: #0f172a;
  --ink-muted: #475569;
}
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  background: var(--bg);
  color: var(--ink);
  max-width: 1040px;
  margin: 2em auto;
  padding: 0 1.5em;
  line-height: 1.5;
}
header { margin-bottom: 2em; }
h1 { font-size: 1.75rem; margin-bottom: 0.25em; }
.meta { color: var(--ink-muted); font-size: 0.9rem; }
.meta code { font-family: "SF Mono", Menlo, monospace; }
.summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1em;
  margin: 1.5em 0;
}
.summary-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1em;
}
.summary-card .label { font-size: 0.8rem; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.summary-card .value { font-size: 1.8rem; font-weight: 600; margin-top: 0.25em; }
.pillar-badge { display: inline-block; padding: 0.1em 0.6em; border-radius: 999px; font-size: 0.75rem; background: #e0e7ff; color: #3730a3; }
.severity {
  display: inline-block;
  padding: 0.1em 0.6em;
  border-radius: 999px;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  color: white;
}
.sev-critical { background: var(--sev-critical); }
.sev-major { background: var(--sev-major); }
.sev-moderate { background: var(--sev-moderate); }
.sev-minor { background: var(--sev-minor); }
.priority {
  display: inline-block;
  padding: 0.1em 0.6em;
  border-radius: 6px;
  font-size: 0.75rem;
  background: #f1f5f9;
  color: var(--ink-muted);
}
.pri-must { background: #fee2e2; color: var(--sev-critical); }
.pri-should { background: #fed7aa; color: var(--sev-major); }
.pri-could { background: #e0f2fe; color: #0369a1; }
.pri-wont { background: #e5e7eb; }
.finding {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1em 1.25em;
  margin-bottom: 0.75em;
}
.finding h3 { margin: 0 0 0.5em; font-size: 1.1rem; }
.finding .meta-row { display: flex; gap: 0.5em; flex-wrap: wrap; font-size: 0.8rem; margin-bottom: 0.5em; }
.finding .summary-text { margin: 0.25em 0 0.5em; color: var(--ink); }
.finding .recommendation { color: var(--ink-muted); font-style: italic; }
.finding .evidence { font-family: "SF Mono", Menlo, monospace; font-size: 0.8rem; background: #f1f5f9; padding: 0.5em; border-radius: 6px; margin-top: 0.5em; }
.rice-score { font-weight: 600; color: var(--ink); }
details { margin-top: 2em; }
summary { cursor: pointer; font-weight: 600; padding: 0.5em 0; }
</style>
</head>
<body>

<header>
  <h1>iOS Audit &mdash; {{ audit.meta.app.name if audit.meta.app else 'Unknown' }}</h1>
  <div class="meta">
    Generated {{ audit.meta.generated_at if audit.meta.generated_at else generated_at }}
    &middot; Commit <code>{{ (audit.meta.repo.git_rev or '')[:12] }}</code>
    {% if audit.meta.repo.git_branch %}on <code>{{ audit.meta.repo.git_branch }}</code>{% endif %}
    {% if audit.meta.app.bundle_id %}&middot; {{ audit.meta.app.bundle_id }}{% endif %}
  </div>
</header>

<section>
  <h2>Summary</h2>
  <div class="summary-grid">
    <div class="summary-card">
      <div class="label">Total Findings</div>
      <div class="value">{{ audit.findings | length }}</div>
    </div>
    <div class="summary-card">
      <div class="label">Ship Blockers</div>
      <div class="value" style="color: var(--sev-critical);">{{ audit.summary.ship_blockers or 0 }}</div>
    </div>
    <div class="summary-card">
      <div class="label">RICE Total</div>
      <div class="value">{{ audit.summary.rice_total or 0 }}</div>
    </div>
    {% for pillar, count in (audit.summary.by_pillar or {}).items() %}
    <div class="summary-card">
      <div class="label">{{ pillar | replace('_', ' ') | title }}</div>
      <div class="value">{{ count }}</div>
    </div>
    {% endfor %}
  </div>
</section>

<section>
  <h2>Findings</h2>
  {% if not audit.findings %}
    <p><em>No findings recorded.</em></p>
  {% endif %}
  {% for f in audit.findings %}
  <div class="finding">
    <h3>{{ f.id }} &mdash; {{ f.title }}</h3>
    <div class="meta-row">
      <span class="pillar-badge">{{ f.pillar | replace('_', ' ') }}</span>
      <span class="severity {{ f.severity | severity_class }}">{{ f.severity }}</span>
      <span class="priority {{ f.priority | priority_class }}">{{ f.priority }}</span>
      {% if f.rice and f.rice.score is not none %}
      <span class="rice-score">RICE {{ f.rice.score }}</span>
      {% endif %}
    </div>
    <p class="summary-text">{{ f.summary }}</p>
    {% if f.recommendation %}
    <p class="recommendation"><strong>Recommendation:</strong> {{ f.recommendation }}</p>
    {% endif %}
    {% if f.evidence %}
    <div class="evidence">
      {% for e in f.evidence %}
      {{ e.path }}{% if e.line_start %}:{{ e.line_start }}{% if e.line_end %}–{{ e.line_end }}{% endif %}{% endif %}<br>
      {% endfor %}
    </div>
    {% endif %}
  </div>
  {% endfor %}
</section>

<details>
  <summary>Meta (raw)</summary>
  <pre style="background:#f1f5f9;padding:1em;border-radius:10px;overflow:auto;font-size:0.75rem">{{ audit.meta | tojson(indent=2) }}</pre>
</details>

</body>
</html>
