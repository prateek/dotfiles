# fork-conflict-resolve: reusable LLM actor. Only callable via workflow_call
# from fork-upstream-sync.yml — there is no `workflow_dispatch` or public
# trigger, so unprivileged actors cannot invoke it directly.
#
# Runs .fork/tools/llm_resolve.py on the supplied list of conflicted files,
# commits the results, pushes back to the sync branch.

name: fork-conflict-resolve

on:
  workflow_call:
    inputs:
      sync_branch:
        description: "Sync branch to check out (e.g. sync/2026-04-18-adc616e)"
        required: true
        type: string
      conflicted_files:
        description: "JSON array of conflicted file paths"
        required: true
        type: string
    outputs:
      resolver_output:
        description: "Raw JSON aggregated from llm_resolve.py invocations"
        value: $${{ jobs.resolve.outputs.resolver_output }}

permissions:
  contents: read

jobs:
  resolve:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    env:
      LLM_PROVIDER: "$llm_provider"
      LLM_MODEL: "$llm_model"
      ANTHROPIC_API_KEY: $${{ secrets.ANTHROPIC_API_KEY }}
      OPENAI_API_KEY: $${{ secrets.OPENAI_API_KEY }}
    outputs:
      resolver_output: $${{ steps.resolve.outputs.resolver_output }}
    steps:
      # Mirror the auth-selection pattern from fork-upstream-sync.yml so the
      # conflict-resolver push survives with either the GitHub App (preferred)
      # or the PAT fallback. See .fork/docs/github-app-setup.md.
      - name: Mint GitHub App installation token (if App is configured)
        id: app-token
        if: $${{ secrets.FORK_APP_ID != '' }}
        uses: actions/create-github-app-token@df432ceedc7162793a195dd1713ff69aefc7379e # v1.11.0
        with:
          app-id: $${{ secrets.FORK_APP_ID }}
          private-key: $${{ secrets.FORK_APP_PRIVATE_KEY }}

      - name: Resolve auth token
        id: auth
        env:
          APP_TOKEN: $${{ steps.app-token.outputs.token }}
          PAT: $${{ secrets.FORK_SYNC_TOKEN }}
        run: |
          if [ -n "$$APP_TOKEN" ]; then
            echo "::add-mask::$$APP_TOKEN"
            echo "token=$$APP_TOKEN" >> "$$GITHUB_OUTPUT"
          elif [ -n "$$PAT" ]; then
            echo "::add-mask::$$PAT"
            echo "token=$$PAT" >> "$$GITHUB_OUTPUT"
          else
            echo "::error::No FORK_APP_ID+FORK_APP_PRIVATE_KEY and no FORK_SYNC_TOKEN configured. See .fork/docs/github-app-setup.md." >&2
            exit 1
          fi

      - name: Checkout sync branch
        uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4.3.1
        with:
          ref: $${{ inputs.sync_branch }}
          fetch-depth: 0
          persist-credentials: true
          token: $${{ steps.auth.outputs.token }}

      - name: Configure git bot identity
        run: |
          git config user.name "fork-sync-bot"
          git config user.email "fork-sync-bot@users.noreply.github.com"

      - name: Set up Python
        uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.1.1
        with:
          python-version: "3.12"

      - name: Install resolver dependencies
        run: |
          python -m pip install --upgrade pip
          if [ "$$LLM_PROVIDER" = "claude" ]; then
            pip install anthropic
          elif [ "$$LLM_PROVIDER" = "openai" ]; then
            pip install openai
          else
            echo "Unknown LLM_PROVIDER=$$LLM_PROVIDER" >&2
            exit 1
          fi

      - name: Run llm_resolve.py on each conflicted file
        id: resolve
        env:
          CONFLICTED_FILES: $${{ inputs.conflicted_files }}
        run: |
          set -euo pipefail
          aggregated='[]'
          count=0
          files=$$(python3 -c "import json,os; print('\n'.join(json.loads(os.environ['CONFLICTED_FILES'])))")
          while IFS= read -r f; do
            [ -z "$$f" ] && continue
            python3 .fork/tools/llm_resolve.py --file "$$f" --provider "$$LLM_PROVIDER" --model "$$LLM_MODEL" \
              > /tmp/llm-out.json
            aggregated=$$(python3 -c "import json,sys; arr=json.loads(sys.argv[1]); arr.append(json.load(open(sys.argv[2]))); print(json.dumps(arr))" "$$aggregated" /tmp/llm-out.json)
            git add "$$f"
            count=$$((count+1))
          done <<< "$$files"
          {
            echo "resolver_output<<RESOLVER_EOF"
            echo "$$aggregated"
            echo "RESOLVER_EOF"
          } >> "$$GITHUB_OUTPUT"
          echo "count=$$count" >> "$$GITHUB_OUTPUT"

      - name: Commit resolved files
        if: steps.resolve.outputs.count != '0'
        run: |
          git commit -m "sync: llm-resolve $${{ steps.resolve.outputs.count }} files"
          git push origin HEAD:$${{ inputs.sync_branch }}

# Design decision: we deliberately do NOT ship a commented-out alternative
# path using anthropics/claude-code-action here. A commented-out action block
# with broad tool access is a booby trap — a careless uncomment would hand
# the resolver unbounded Edit/Bash/WebFetch capability on a conflicted tree.
# If we ever adopt claude-code-action, add it as a live step with an explicit
# allowlist (e.g. `--allowedTools Read,Edit,Grep`) and re-run the security
# review. For now the provider-agnostic llm_resolve.py path is authoritative.
