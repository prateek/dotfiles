# Fastlane ASC API key — copy to fastlane/.env (gitignored) and fill in.
#
# Generate the .p8 file at https://appstoreconnect.apple.com/access/api
#   1. Users and Access → Integrations → App Store Connect API
#   2. Generate API Key (pick "Admin" or "App Manager" scope)
#   3. Download AuthKey_XXXXXXXXXX.p8 (you can only download once)
#   4. Store it at ~/.config/app-store-connect/AuthKey_XXXXXXXXXX.p8
#      or anywhere stable outside the repo
#
# The three env vars below match fastlane's canonical names from
# app_store_connect_api_key.rb. Do NOT rename them.

APP_STORE_CONNECT_API_KEY_KEY_ID=XXXXXXXXXX
APP_STORE_CONNECT_API_KEY_ISSUER_ID=00000000-0000-0000-0000-000000000000
APP_STORE_CONNECT_API_KEY_KEY_FILEPATH=/Users/you/.config/app-store-connect/AuthKey_XXXXXXXXXX.p8

# Optional project-level overrides the Fastfile reads.
SCHEME=MyApp
WORKSPACE=MyApp.xcworkspace
CONFIGURATION=Release
