<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BundleIdentifier</key>
	<string>com.example.geo</string>
	<key>WindowGeometry</key>
	<string>{{width}}x{{height}}+0+0</string>
	<key>ManagedBy</key>
	<string>{{ .chezmoi.username }}@{{ .chezmoi.hostname }}</string>
	<key>SnapZones</key>
	<array>
		<string>{{topleft}}</string>
		<string>{{topright}}</string>
		<string>{{bottomleft}}</string>
		<string>{{bottomright}}</string>
	</array>
</dict>
</plist>
