{{ template "script_lib.sh" . }}

# packages.toml sha256: {{ include ".chezmoidata/packages.toml" | sha256sum }}

{{- if .run_install_scripts }}
if ! have gh; then
  warn "gh is not installed; skipping gh extension install."
  exit 0
fi

extensions=(
{{- $profile_data := index .packages.profiles (.install_profile | default .packages.default_profile) }}
{{- range ($profile_data.gh_extensions | default list) }}
  {{ .name | quote }}
{{- end }}
)

extensions_root="${XDG_DATA_HOME:-$HOME/.local/share}/gh/extensions"

# `${arr[@]+"${arr[@]}"}` keeps the loop safe under bash 3.2 (system /bin/bash on
# macOS) when a future profile omits `gh_extensions` and the array is empty.
for ext in ${extensions[@]+"${extensions[@]}"}; do
  # gh enforces a `gh-` repo-name prefix on extensions; the on-disk directory
  # mirrors the repo basename verbatim (no extra `gh-`).
  name="${ext##*/}"
  if [ -d "$extensions_root/$name" ]; then
    log "gh extension already installed: $ext"
    continue
  fi
  run_timed "gh extension install $ext" gh extension install "$ext" \
    || warn "gh extension install failed for $ext; retry with: gh extension install $ext"
done
{{- else }}
log "Install scripts disabled; skipping gh extension install."
{{- end }}
