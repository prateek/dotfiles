{{ template "script_lib.sh" . }}

# Hammerspoon source sha256: {{ include "dot_hammerspoon/init.fnl" | sha256sum }}

{{- if and .run_install_scripts .features.compile_hammerspoon }}
src="$HOME/.hammerspoon/init.fnl"
out="$HOME/.hammerspoon/init.generated.lua"

if [ ! -f "$src" ]; then
  warn "Hammerspoon source missing: $src"
  exit 0
fi

if ! have fennel; then
  warn "fennel is not installed; skipping Hammerspoon compilation."
  exit 0
fi

tmp="${out}.tmp"
fennel --compile "$src" > "$tmp"
mv "$tmp" "$out"
{{- else }}
log "Hammerspoon compilation disabled."
{{- end }}
