{{ template "script_lib.sh" . }}

# packages.toml sha256: {{ include ".chezmoidata/packages.toml" | sha256sum }}
# machines.toml sha256: {{ include ".chezmoidata/machines.toml" | sha256sum }}
# ios-triple.json sha256: {{ include "dot_agents/state/ios-triple.json" | sha256sum }}

{{- $f := includeTemplate "features.tmpl" . | fromJson -}}
{{- if $f.run_install_scripts }}
machine_type={{ $f.machine_type | quote }}
has_apple_development={{ has "apple-development" $f.groups | toString | quote }}

if [ "$has_apple_development" != "true" ]; then
  log "Xcode install skipped for $machine_type machine type (no apple-development group)."
  exit 0
fi

if [ "$(uname -s)" != "Darwin" ]; then
  log "Xcode install skipped on non-macOS host."
  exit 0
fi

brew_shellenv
have brew || die "Homebrew is required before Xcode setup can run."
have jq || die "jq is required before Xcode setup can run; rerun brew bundle."
have xcodes || die "xcodes is required for Xcode setup; rerun brew bundle."

triple_file="$HOME/.agents/state/ios-triple.json"
[ -r "$triple_file" ] || die "Missing Xcode version pin: $triple_file"
xcode_version="$(jq -r '.xcode_version // empty' "$triple_file")"
[ -n "$xcode_version" ] || die "Missing .xcode_version in $triple_file"
# Optional minimum: when set, any selected Xcode >= it satisfies the pin.
xcode_version_min="$(jq -r '.xcode_version_min // empty' "$triple_file")"

# version_ge a b -> 0 (true) if a >= b, comparing dotted versions via sort -V.
version_ge() { [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -n1)" = "$1" ]; }

xcode_required_brews=(
{{- $xb := list -}}
{{- $xseen := list -}}
{{- range $gname := $f.groups -}}
{{-   $g := index $.packages.groups $gname -}}
{{-   range default (list) (dig "xcode_required_brews" (list) $g) -}}
{{-     if not (has .name $xseen) -}}
{{-       $xb = mustAppend $xb .name -}}
{{-       $xseen = mustAppend $xseen .name -}}
{{-     end -}}
{{-   end -}}
{{- end }}
{{- range $xb }}
  {{ . | quote }}
{{- end }}
)

# check & set: use a satisfying Xcode if present, otherwise download it.
select_version="$xcode_version"
have_xcode=0
if xcodes installed "$xcode_version" >/dev/null 2>&1; then
  have_xcode=1
elif [ -n "$xcode_version_min" ]; then
  current_xcode="$(xcodebuild -version 2>/dev/null | awk 'NR==1 {print $2}' || true)"
  if [ -n "$current_xcode" ] && version_ge "$current_xcode" "$xcode_version_min"; then
    have_xcode=1
    select_version="$current_xcode"
  fi
fi

if [ "$have_xcode" = "1" ]; then
  log "Xcode $select_version satisfies the pin (>= ${xcode_version_min:-$xcode_version})."
else
  # Not present. xcodes needs an interactive Apple ID login to download, so install
  # only when interactive or explicitly forced; otherwise fail loudly rather than
  # silently skip (an apple-development machine is expected to end up with Xcode).
  force_xcode=0
  case "${DOTFILES_INSTALL_XCODE:-}" in true|1|yes|on) force_xcode=1 ;; esac
  if [ "$force_xcode" = "1" ] || { [ -t 0 ] && [ -t 1 ]; }; then
    warn "Installing Xcode $xcode_version through xcodes; this may prompt for Apple ID login."
    dotfiles_sudo_start "Xcode install needs administrator access. Enter your macOS password if prompted."
    run_timed "xcodes install $xcode_version" xcodes install "$xcode_version" --experimental-unxip
  else
    die "Xcode $xcode_version is not installed and this apply is non-interactive. xcodes needs an interactive Apple ID login to download Xcode. Re-run interactively, or set DOTFILES_INSTALL_XCODE=true to force the download."
  fi
fi

dotfiles_sudo_start "Xcode setup needs administrator access. Enter your macOS password if prompted."
run_timed "xcodes select $select_version" xcodes select "$select_version"
run_timed "xcodebuild license" sudo xcodebuild -license accept
run_timed "xcodebuild first launch" sudo xcodebuild -runFirstLaunch

# ${arr[@]+"${arr[@]}"} stays safe under macOS Bash 3.2 + set -u if the group declares none.
for formula in ${xcode_required_brews[@]+"${xcode_required_brews[@]}"}; do
  run_timed "brew install $formula" brew install "$formula"
done
{{- else }}
log "Xcode install disabled."
{{- end }}
