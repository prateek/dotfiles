{{ template "script_lib.sh" . }}

# packages.toml sha256: {{ include ".chezmoidata/packages.toml" | sha256sum }}
# ios-triple.json sha256: {{ include "dot_agents/state/ios-triple.json" | sha256sum }}

{{- if .run_install_scripts }}
{{- $machineType := coalesce (env "DOTFILES_MACHINE_TYPE") (dig "machine_type" "" .) .packages.default_machine_type }}
machine_type={{ $machineType | quote }}
has_apple={{ has "dev-apple" (index .packages.machine_types $machineType).groups | toString | quote }}
install_xcode={{ .install_xcode | default false | toString | quote }}
env_install_xcode={{ env "DOTFILES_INSTALL_XCODE" | quote }}
if [ -n "$env_install_xcode" ]; then
  install_xcode="$env_install_xcode"
fi

case "$install_xcode" in
  true|1|yes|on) install_xcode=1 ;;
  false|0|no|off) install_xcode=0 ;;
  *) die "install_xcode/DOTFILES_INSTALL_XCODE must be true or false." ;;
esac

if [ "$has_apple" != "true" ]; then
  log "Xcode install skipped for $machine_type machine type (no dev-apple group)."
  exit 0
fi

if [ "$(uname -s)" != "Darwin" ]; then
  log "Xcode install skipped on non-macOS host."
  exit 0
fi

brew_shellenv
have brew || die "Homebrew is required before Xcode setup can run."
have jq || die "jq is required before Xcode setup can run; rerun brew bundle."
have xcodes || die "xcodes is required for Xcode setup; rerun brew bundle."

triple_file="$HOME/.agents/state/ios-triple.json"
[ -r "$triple_file" ] || die "Missing Xcode version pin: $triple_file"
xcode_version="$(jq -r '.xcode_version // empty' "$triple_file")"
[ -n "$xcode_version" ] || die "Missing .xcode_version in $triple_file"

xcode_required_brews=(
{{- $xb := list -}}
{{- $xseen := list -}}
{{- range $gname := (index .packages.machine_types $machineType).groups -}}
{{-   $g := index $.packages.groups $gname -}}
{{-   range default (list) (dig "xcode_required_brews" (list) $g) -}}
{{-     if not (has .name $xseen) -}}
{{-       $xb = mustAppend $xb .name -}}
{{-       $xseen = mustAppend $xseen .name -}}
{{-     end -}}
{{-   end -}}
{{- end }}
{{- range $xb }}
  {{ . | quote }}
{{- end }}
)

if xcodes installed "$xcode_version" >/dev/null 2>&1; then
  log "Xcode $xcode_version already installed."
elif [ "$install_xcode" = "1" ]; then
  warn "Installing Xcode $xcode_version through xcodes may prompt for Apple ID login."
  dotfiles_sudo_start "Xcode install needs administrator access. Enter your macOS password if prompted."
  run_timed "xcodes install $xcode_version" xcodes install "$xcode_version" --experimental-unxip
else
  warn "Xcode $xcode_version is not installed. Skipping Xcode download because xcodes requires Apple ID login."
  warn "Run this when you want the Apple ID-backed Xcode download: DOTFILES_INSTALL_XCODE=true chezmoi apply"
  if [ "${#xcode_required_brews[@]}" -gt 0 ]; then
    warn "Skipping Xcode-required Homebrew formulae until Xcode is installed: ${xcode_required_brews[*]}"
  fi
  exit 0
fi

dotfiles_sudo_start "Xcode setup needs administrator access. Enter your macOS password if prompted."
run_timed "xcodes select $xcode_version" xcodes select "$xcode_version"
run_timed "xcodebuild license" sudo xcodebuild -license accept
run_timed "xcodebuild first launch" sudo xcodebuild -runFirstLaunch

# ${arr[@]+"${arr[@]}"} stays safe under macOS Bash 3.2 + set -u if the group declares none.
for formula in ${xcode_required_brews[@]+"${xcode_required_brews[@]}"}; do
  run_timed "brew install $formula" brew install "$formula"
done
{{- else }}
log "Xcode install disabled."
{{- end }}
