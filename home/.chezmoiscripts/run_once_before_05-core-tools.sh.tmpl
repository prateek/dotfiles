{{ template "script_lib.sh" . }}

{{- if .run_install_scripts }}
brew_shellenv

# git, chezmoi, and uv are the minimum to run chezmoi apply: chezmoi-managed
# `modify_*` scripts use `#!/usr/bin/env -S uv run --script` shebangs and
# execute during chezmoi's file phase, before brew-bundle installs other
# runtimes.
missing=()
for tool in git chezmoi uv; do
  if ! have "$tool"; then
    missing+=("$tool")
  fi
done

if [ "${#missing[@]}" -eq 0 ]; then
  exit 0
fi

if ! have brew; then
  die "Missing core tools (${missing[*]}) and Homebrew is unavailable."
fi

brew install "${missing[@]}"
{{- else }}
log "Install scripts disabled; skipping core tool setup."
{{- end }}
