{{- $forceValue := env "DOTFILES_FORCE_MACOS_DEFAULTS" | lower -}}
{{- $forceMacosDefaults := or (eq $forceValue "1") (eq $forceValue "true") (eq $forceValue "yes") (eq $forceValue "on") -}}
{{- if and .run_install_scripts .apply_macos_defaults $forceMacosDefaults -}}
{{ template "script_lib.sh" . }}

{{ $snapshotHelper := joinPath .chezmoi.workingTree "scripts/macos/defaults-snapshot.sh" }}
{{ $snapshotHelperHash := output "shasum" "-a" "256" $snapshotHelper | trim | splitList " " | first }}
{{ $defaultsHash := includeTemplate "macos-defaults.sh.tmpl" . | sha256sum }}
# macos-defaults payload sha256: {{ $defaultsHash }}
# macos-defaults snapshot helper sha256: {{ $snapshotHelperHash }}
# macos-defaults force: 1

{{ template "macos-defaults-runner.sh.tmpl" (dict "root" . "defaultsHash" $defaultsHash "snapshotHelper" $snapshotHelper "forceMacosDefaults" true) }}
{{- end -}}
