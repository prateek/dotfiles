{{ template "script_lib.sh" . }}

# Raycast Orca extension package sha256: {{ include "dot_config/raycast/extensions/orca-worktree/package.json" | sha256sum }}
# Raycast Orca extension lockfile sha256: {{ include "dot_config/raycast/extensions/orca-worktree/package-lock.json" | sha256sum }}

{{- if and .run_install_scripts (eq (includeTemplate "package-cask-enabled.tmpl" (dict "root" . "name" "raycast")) "true") }}
if ! have npm; then
  warn "npm is not installed; skipping Raycast extension dependency install."
  exit 0
fi

extension_dir="$HOME/.config/raycast/extensions/orca-worktree"
if [ ! -f "$extension_dir/package-lock.json" ]; then
  warn "Raycast Orca extension lockfile missing: $extension_dir/package-lock.json"
  exit 0
fi

if run_timed "raycast orca-worktree npm ci" npm ci --omit=dev --prefix "$extension_dir"; then
  (
    cd "$extension_dir" || exit 1
    run_timed "raycast orca-worktree ray build" npm exec -- ray build --non-interactive
  ) || warn "Raycast Orca extension build failed; retry with: cd $extension_dir && npm exec -- ray build --non-interactive"
else
  warn "Raycast Orca extension dependency install failed; retry with: npm ci --omit=dev --prefix $extension_dir"
fi
{{- else }}
log "Raycast extension dependency install skipped."
{{- end }}
