{{ template "script_lib.sh" . }}

# packages.toml sha256: {{ include ".chezmoidata/packages.toml" | sha256sum }}
# brewfile.tmpl sha256: {{ include ".chezmoitemplates/brewfile.tmpl" | sha256sum }}

{{- if .run_install_scripts }}
profile={{ .install_profile | default .packages.default_profile | quote }}
mas_opt_in={{ env "DOTFILES_INSTALL_MAS_APPS" | default "false" | quote }}

case "$mas_opt_in" in
  1|true|TRUE|yes|YES|on|ON) ;;
  *)
    if [ "$profile" = "full" ]; then
      warn "Mac App Store installs disabled; set DOTFILES_INSTALL_MAS_APPS=true to opt in."
    fi
    ;;
esac

brew_shellenv
have brew || die "Homebrew is required before brew bundle can run."

# Render the desired Brewfile inline via the shared template fragment.
# Single source of truth: home/.chezmoitemplates/brewfile.tmpl. Audit
# scripts hit the same fragment via scripts/packages/render-brewfile.
brewfile="$(mktemp "${TMPDIR:-/tmp}/dotfiles-brewfile.XXXXXX")"
trap 'rm -f "$brewfile"' EXIT
cat <<'BREWFILE' >"$brewfile"
{{ template "brewfile.tmpl" . -}}
BREWFILE

if HOMEBREW_NO_AUTO_UPDATE=1 brew bundle check --no-upgrade --verbose --file "$brewfile"; then
  log "Homebrew Bundle dependencies are already satisfied; skipping install."
  exit 0
fi

if [ "$profile" = "full" ]; then
  log "Updating Homebrew before applying the full package profile."
  run_timed "brew update" brew update --quiet
fi

if [ -n "${DOTFILES_HOMEBREW_DOWNLOAD_CONCURRENCY:-}" ]; then
  export HOMEBREW_DOWNLOAD_CONCURRENCY="$DOTFILES_HOMEBREW_DOWNLOAD_CONCURRENCY"
elif [ -z "${HOMEBREW_DOWNLOAD_CONCURRENCY:-}" ]; then
  export HOMEBREW_DOWNLOAD_CONCURRENCY=auto
fi

# Pre-create taps before brew bundle. brew bundle handles taps but
# pre-tapping with explicit URLs gives clearer errors when a tap fails.
if command -v awk >/dev/null 2>&1; then
  taps="$(awk -F'"' '/^tap "/ {print $2 "\t" $4}' "$brewfile" | sort -u)"
  if [ -n "$taps" ]; then
    existing_taps="$(brew tap 2>/dev/null || true)"
    while IFS="$(printf '\t')" read -r tap url; do
      [ -n "$tap" ] || continue
      if ! printf '%s\n' "$existing_taps" | grep -qx "$tap"; then
        if [ -n "$url" ]; then
          run_timed "brew tap $tap" brew tap "$tap" "$url"
        else
          run_timed "brew tap $tap" brew tap "$tap"
        fi
      fi
    done <<EOF_TAPS
$taps
EOF_TAPS
  fi
fi

bundle_args=(bundle install --no-upgrade --file "$brewfile")
bundle_jobs="${DOTFILES_HOMEBREW_BUNDLE_JOBS:-${HOMEBREW_BUNDLE_JOBS:-auto}}"
if brew bundle install --help 2>/dev/null | grep -q -- '--jobs'; then
  bundle_args+=(--jobs "$bundle_jobs")
  log "Homebrew Bundle formula jobs: $bundle_jobs"
elif [ -n "${DOTFILES_HOMEBREW_BUNDLE_JOBS:-}${HOMEBREW_BUNDLE_JOBS:-}" ]; then
  warn "Installed Homebrew does not support brew bundle --jobs; using sequential formula installs."
fi

# Do not pre-warm sudo here. Homebrew resets the sudo timestamp when `brew`
# starts; cask/pkg installers will prompt through Homebrew only when needed.
run_timed "brew bundle install ($profile)" brew "${bundle_args[@]}"
{{- else }}
log "Package install disabled; skipping brew bundle."
{{- end }}
