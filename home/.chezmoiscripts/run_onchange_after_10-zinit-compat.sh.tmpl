{{ template "script_lib.sh" . }}

{{- if .manage_zinit_external }}
zinit_dir="${XDG_DATA_HOME:-$HOME/.local/share}/zinit/zinit.git"
legacy_dir="$HOME/.zinit"
legacy_link="$legacy_dir/bin"

if [ ! -d "$zinit_dir" ]; then
  warn "zinit external is not present yet: $zinit_dir"
  exit 0
fi

mkdir -p "$legacy_dir"
if [ -e "$legacy_link" ] || [ -L "$legacy_link" ]; then
  if [ "$(readlink "$legacy_link" 2>/dev/null || true)" = "$zinit_dir" ]; then
    exit 0
  fi
  if [ -d "$legacy_link" ] && [ ! -L "$legacy_link" ]; then
    warn "Leaving existing legacy zinit directory in place: $legacy_link"
    exit 0
  fi
fi
ln -snf "$zinit_dir" "$legacy_link"
{{- else }}
log "zinit external disabled."
{{- end }}
