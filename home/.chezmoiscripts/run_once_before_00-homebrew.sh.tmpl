{{ template "script_lib.sh" . }}

{{- $f := includeTemplate "features.tmpl" . | fromJson -}}
{{- if $f.run_install_scripts }}
if [ "$(uname -s)" != "Darwin" ]; then
  log "Homebrew setup skipped on non-macOS host."
  exit 0
fi

brew_shellenv
if have brew; then
  exit 0
fi

log "Installing Homebrew."
dotfiles_sudo_start "Homebrew install needs administrator access. Enter your macOS password if prompted."
NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
brew_shellenv
have brew || die "Homebrew install finished but brew is not on PATH."
{{- else }}
log "Install scripts disabled; skipping Homebrew setup."
{{- end }}
