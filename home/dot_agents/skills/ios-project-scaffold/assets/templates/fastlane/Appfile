app_identifier("__BUNDLE_ID__")   # bundle identifier; update to match Project.swift
team_id("__TEAM_ID__")            # Apple Developer Team ID (10-char); find at developer.apple.com/account → Membership

# itc_team_id and team_id are historically different; both default to reading
# from the ASC API key's issuer when asc_auth runs, so leaving them commented
# is usually fine for API-key-based flows.
