#!/usr/bin/env bash

set -euo pipefail

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "error: missing required command '$1'. Run 'make setup-tools'." >&2
    exit 1
  }
}

require_cmd git
require_cmd swiftformat
require_cmd swiftlint
require_cmd typos

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

staged_files=()
swift_files=()
typo_files=()

while IFS= read -r -d '' file; do
  [[ -f "$file" ]] || continue
  staged_files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [[ ${#staged_files[@]} -eq 0 ]]; then
  exit 0
fi

for file in "${staged_files[@]}"; do
  case "$file" in
    *.swift)
      swift_files+=("$file")
      typo_files+=("$file")
      ;;
    *.md|*.markdown|*.txt|*.yml|*.yaml|*.toml|*.json|*.plist|*.strings|*.xcconfig|*.pbxproj|*.gitignore)
      typo_files+=("$file")
      ;;
  esac
done

if [[ ${#swift_files[@]} -gt 0 ]]; then
  swiftformat "${swift_files[@]}"
  git add -- "${swift_files[@]}"
  swiftformat --lint "${swift_files[@]}"

  for file in "${swift_files[@]}"; do
    swiftlint lint --quiet --path "$file"
  done
fi

if [[ ${#typo_files[@]} -gt 0 ]]; then
  typos "${typo_files[@]}"
fi
