#!/usr/bin/env python3
import copy
import io
import json
import pathlib
import plistlib
import sys

source_path = pathlib.Path("{{ .chezmoi.sourceDir }}/.chezmoiassets/cmux/preferences.json")
DESIRED_JSON = source_path.read_text()

raw = sys.stdin.buffer.read()
if raw.strip():
    current = plistlib.loads(raw)
    if not isinstance(current, dict):
        current = {}
else:
    current = {}

desired = json.loads(DESIRED_JSON)

current["appearanceMode"] = desired["appearanceMode"]
current["browserHostWhitelist"] = "\n".join(desired["browserHostWhitelist"])
current["browserThemeMode"] = desired["browserThemeMode"]

for name, shortcut in desired["shortcuts"].items():
    key = f"shortcut.{name}"
    payload = json.dumps(shortcut, sort_keys=True, separators=(",", ":")).encode()
    current[key] = payload

for name, value in desired["sidebar"].items():
    current[f"sidebar{name[0].upper()}{name[1:]}"] = copy.deepcopy(value)

output = io.BytesIO()
plistlib.dump(current, output, fmt=plistlib.FMT_BINARY, sort_keys=False)
sys.stdout.buffer.write(output.getvalue())
