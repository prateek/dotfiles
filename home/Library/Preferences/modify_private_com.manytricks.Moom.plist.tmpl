#!/usr/bin/env python3
import copy
import io
import pathlib
import plistlib
import sys

source_path = pathlib.Path("{{ .chezmoi.sourceDir }}/.chezmoiassets/com.manytricks.Moom.plist")

with source_path.open("rb") as source_file:
    desired = plistlib.load(source_file)

raw = sys.stdin.buffer.read()
if raw.strip():
    current = plistlib.loads(raw)
    if not isinstance(current, dict):
        current = {}
else:
    current = {}

for key, value in desired.items():
    current[key] = copy.deepcopy(value)

output = io.BytesIO()
plistlib.dump(current, output, fmt=plistlib.FMT_BINARY, sort_keys=False)
sys.stdout.buffer.write(output.getvalue())
