#!/usr/bin/env python3
import copy
import io
import json
import pathlib
import plistlib
import sys

source_path = pathlib.Path("{{ .chezmoi.sourceDir }}/.chezmoiassets/Library/Preferences/com.prakashjoshipax.VoiceInk.json")
desired = json.loads(source_path.read_text())

raw = sys.stdin.buffer.read()
if raw.strip():
    current = plistlib.loads(raw)
    if not isinstance(current, dict):
        current = {}
else:
    current = {}

for key, value in desired.items():
    if key == "customPrompts":
        current[key] = json.dumps(
            value,
            ensure_ascii=False,
            separators=(",", ":"),
        ).encode("utf-8")
    else:
        current[key] = copy.deepcopy(value)

output = io.BytesIO()
plistlib.dump(current, output, fmt=plistlib.FMT_BINARY, sort_keys=False)
sys.stdout.buffer.write(output.getvalue())
