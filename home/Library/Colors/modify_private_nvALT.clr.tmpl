#!/usr/bin/env python3
import json
import io
import pathlib
import plistlib
import sys

source_path = pathlib.Path("{{ .chezmoi.sourceDir }}/.chezmoiassets/Library/Colors/nvALT.clr.json")
entries = json.loads(source_path.read_text())

key_indexes = list(range(2, 2 + len(entries)))
array_class_index = 2 + len(entries)
color_array_index = array_class_index + 1
first_color_index = color_array_index + 1
color_class_index = first_color_index + 1
color_indexes = [first_color_index]
color_indexes.extend(range(color_class_index + 1, color_class_index + len(entries)))

objects = [
    "$null",
    {
        "$class": plistlib.UID(array_class_index),
        "NS.objects": [plistlib.UID(index) for index in key_indexes],
    },
]
objects.extend(entry["name"] for entry in entries)
objects.append(
    {
        "$classes": ["NSMutableArray", "NSArray", "NSObject"],
        "$classname": "NSMutableArray",
    }
)
objects.append(
    {
        "$class": plistlib.UID(array_class_index),
        "NS.objects": [plistlib.UID(index) for index in color_indexes],
    }
)

for index, entry in enumerate(entries):
    if index == 1:
        objects.append(
            {
                "$classes": ["NSColor", "NSObject"],
                "$classname": "NSColor",
            }
        )
    objects.append(
        {
            "$class": plistlib.UID(color_class_index),
            "NSColorSpace": 2,
            "NSRGB": (" ".join(entry["rgb"]) + "\0").encode("ascii"),
        }
    )

payload = {
    "$archiver": "NSKeyedArchiver",
    "$objects": objects,
    "$top": {
        "NSColors": plistlib.UID(color_array_index),
        "NSKeys": plistlib.UID(1),
    },
    "$version": 100000,
}

output = io.BytesIO()
plistlib.dump(payload, output, fmt=plistlib.FMT_BINARY, sort_keys=False)
sys.stdout.buffer.write(output.getvalue())
