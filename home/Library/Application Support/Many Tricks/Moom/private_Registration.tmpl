{{- /*
  Moom registration file. Materialized only when secrets_enabled=true AND
  .secrets.refs.moom_license is a real op:// reference.

  Verify the target path on first `chezmoi apply --dry-run`. Many Tricks
  apps store registration under either ~/Library/Application Support/Many
  Tricks/<App>/Registration or a per-app license bundle.

  Set the ref locally:
      chezmoi edit-config
  and add:
      [data.secrets.refs]
      moom_license = "op://<vault>/<item>/<field>"
  Then enable [data.machines_local] secrets_enabled = true and run: chezmoi apply
*/ -}}
{{- if (includeTemplate "features.tmpl" . | fromJson).secrets_enabled -}}
{{-   if not .secrets.refs.moom_license -}}
{{-     fail "secrets_enabled is true but secrets.refs.moom_license is empty; set it in ~/.config/chezmoi/chezmoi.toml under [data.secrets.refs] or disable secrets to skip license materialization" -}}
{{-   end -}}
{{ onepasswordRead .secrets.refs.moom_license }}
{{- end -}}
