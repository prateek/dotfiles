#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
"""Merge the tracked Orca settings (base + this machine_type's overlay) into the
`settings` subtree of the app-rewritten orca-data.json; pass the rest through.
"""
import base64
import json
import sys

{{- $mt := coalesce (dig "machine_type" "" .) "personal" }}
base = json.loads(
    base64.b64decode(
        "{{ includeTemplate "orca-settings.base.json.tmpl" . | b64enc }}"
    ).decode()
)
overlay = json.loads(
    base64.b64decode(
        "{{ dig "orca" "machine_types" $mt (dict) . | toJson | b64enc }}"
    ).decode()
)
desired = {**base, **overlay}


def load_current(text: str) -> dict:
    if not text.strip():
        return {}
    value = json.loads(text)
    return value if isinstance(value, dict) else {}


def semantic_equal(left: str, right: str) -> bool:
    try:
        return json.loads(left) == json.loads(right)
    except Exception:
        return False


current_text = sys.stdin.read()
current = load_current(current_text)
current.setdefault("settings", {}).update(desired)

merged_text = json.dumps(current, indent=2, ensure_ascii=False) + "\n"
sys.stdout.write(current_text if semantic_equal(current_text, merged_text) else merged_text)
