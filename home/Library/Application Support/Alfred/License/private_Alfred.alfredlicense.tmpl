{{- /*
  Alfred license file. Materialized only when secrets_enabled=true AND
  .secrets.refs.alfred_license is a real op:// reference.

  Verify the target path on first `chezmoi apply --dry-run`. Alfred
  typically stores its license at ~/Library/Application Support/Alfred/
  License/Alfred.alfredlicense.

  Set the ref locally:
      chezmoi edit-config
  and add:
      [data.secrets.refs]
      alfred_license = "op://<vault>/<item>/<field>"
  Then enable [data.machines_local] secrets_enabled = true and run: chezmoi apply
*/ -}}
{{- if (includeTemplate "features.tmpl" . | fromJson).secrets_enabled -}}
{{-   if not .secrets.refs.alfred_license -}}
{{-     fail "secrets_enabled is true but secrets.refs.alfred_license is empty; set it in ~/.config/chezmoi/chezmoi.toml under [data.secrets.refs] or disable secrets to skip license materialization" -}}
{{-   end -}}
{{ onepasswordRead .secrets.refs.alfred_license }}
{{- end -}}
