{{- /*
  BetterTouchTool license file. Materialized only when secrets_enabled=true
  AND .secrets.refs.bettertouchtool_license is a real op:// reference.

  Verify the target path on first `chezmoi apply --dry-run`. BTT typically
  installs to ~/Library/Application Support/BetterTouchTool/license.bttlicense
  but new major versions sometimes relocate.

  Set the ref locally:
      chezmoi edit-config
  and add:
      [data.secrets.refs]
      bettertouchtool_license = "op://<vault>/<item>/<field>"
  Then: DOTFILES_SECRETS_ENABLED=true chezmoi apply
*/ -}}
{{- if .secrets_enabled -}}
{{-   if not .secrets.refs.bettertouchtool_license -}}
{{-     fail "secrets_enabled=true but secrets.refs.bettertouchtool_license is empty; set it in ~/.config/chezmoi/chezmoi.toml under [data.secrets.refs] or run with secrets_enabled=false to skip license materialization" -}}
{{-   end -}}
{{ onepasswordRead .secrets.refs.bettertouchtool_license }}
{{- end -}}
