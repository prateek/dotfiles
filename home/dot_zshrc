# shellcheck shell=zsh
#
# Workaround for an Orca shell-ready ZDOTDIR bug.
#
# Orca <= 1.3.51 generates a shell-ready zsh wrapper at
# ~/Library/Application Support/orca/shell-ready/zsh/ that sources the user's
# ~/.zshenv first and then *unconditionally* overrides ZDOTDIR back to its
# own wrapper dir. The XDG idiom in our .zshenv —
#   export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"
# — therefore never takes effect under Orca, and ~/.config/zsh/.zshrc never
# sources. The wrapper then sources $HOME/.zshrc (this file) as a fallback.
#
# Fix is on the user's fork branch as `prateek/fix-zdotdir-xdg-bug` (commit
# b5c56b9e in stablyai/orca). Once that's merged + an Orca release with it
# is installed, Orca's wrapper sources ~/.config/zsh/.zshrc directly and
# this file is never reached. **Delete ~/.zshrc (and home/dot_zshrc in the
# dotfiles repo) at that point** — the WORKAROUND ACTIVE notice below will
# remind you on every fresh Orca shell until then.

# If the real config already loaded (PR-merged Orca, Ghostty.app, etc.),
# bail out so we never double-source.
[[ -z "${ZSH_INIT:-}" ]] || return

# Only fall back when Orca's wrapper is the live ZDOTDIR. In every other
# context zsh has already sourced (or will source) ~/.config/zsh/.zshrc
# directly via ZDOTDIR resolution and this file should stay quiet.
case "${ZDOTDIR%/}" in
  */shell-ready/zsh)
    print -u2 -- 'shell-ready: WORKAROUND ACTIVE — sourcing ~/.config/zsh/.zshrc as fallback. Delete ~/.zshrc + home/dot_zshrc once Orca >= the prateek/fix-zdotdir-xdg-bug release is installed.'
    # Repoint ZDOTDIR + ZSHCONFIG at the user's real config dir before
    # sourcing so init.sh / extra/*.zsh / lib/*.zsh resolve correctly.
    # Without this, the user's .zshrc would resolve ZSHCONFIG to Orca's
    # wrapper dir and bail out with "Could not find the init script…".
    export ZDOTDIR="${XDG_CONFIG_HOME:-$HOME/.config}/zsh"
    export ZSHCONFIG="$ZDOTDIR"
    if [[ -r "$ZDOTDIR/.zshrc" ]]; then
      source "$ZDOTDIR/.zshrc"
    fi
    ;;
esac
