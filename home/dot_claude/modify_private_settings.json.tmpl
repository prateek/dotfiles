#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.14"
# dependencies = []
# ///
"""Deep-merge chezmoi's desired Claude settings into ~/.claude/settings.json.

Desired wins on conflicts; unrelated keys pass through untouched. Malformed
input propagates from `json.loads` to chezmoi. See SKILL.md and ADR 0007 for
the override model and the stale-key trade-off.

Two desired fragments: the generated plugin-marketplace fragment and the
hand-maintained managed settings (claude-settings-managed.json.tmpl). The
managed fragment merges last and wins where the two overlap.
"""
import base64
import json
import sys

plugins = json.loads(
    base64.b64decode(
        "{{ includeTemplate "agent-claude-plugin-settings.json.tmpl" . | b64enc }}"
    ).decode()
)
plugins.pop("_generated", None)  # template-file marker, not a settings value

managed = json.loads(
    base64.b64decode(
        "{{ includeTemplate "claude-settings-managed.json.tmpl" . | b64enc }}"
    ).decode()
)


def deep_merge(base, overlay):
    """Deep-merge overlay into base in place; overlay wins on conflicts.

    Recurses into any pair of mapping-like values (anything with `.items()`).
    """
    for key, value in overlay.items():
        existing = base.get(key)
        if hasattr(existing, "items") and hasattr(value, "items"):
            deep_merge(existing, value)
        else:
            base[key] = value
    return base


def load_current(text: str) -> dict:
    if not text.strip():
        return {}
    value = json.loads(text)
    return value if isinstance(value, dict) else {}


def semantic_equal(left: str, right: str) -> bool:
    try:
        return json.loads(left) == json.loads(right)
    except Exception:
        return False


current_text = sys.stdin.read()
current = load_current(current_text)
deep_merge(current, plugins)
deep_merge(current, managed)

merged_text = json.dumps(current, indent=2) + "\n"
sys.stdout.write(current_text if semantic_equal(current_text, merged_text) else merged_text)
