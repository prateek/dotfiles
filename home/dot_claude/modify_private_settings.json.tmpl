#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Merge repo-owned Claude Code plugin settings into the live settings file.

Claude Code writes unrelated user preferences and plugin cache state beside
settings.json. Chezmoi owns the local marketplace declaration and which
repo-rendered plugins should be enabled, while preserving everything else.
"""
import base64
import copy
import json
import sys

desired = json.loads(
    base64.b64decode(
        "{{ includeTemplate "agent-claude-plugin-settings.json.tmpl" . | b64enc }}"
    ).decode()
)


def load_current(text: str) -> dict:
    if not text.strip():
        return {}
    value = json.loads(text)
    return value if isinstance(value, dict) else {}


def semantic_equal(left: str, right: str) -> bool:
    try:
        return json.loads(left) == json.loads(right)
    except Exception:
        return False


current_text = sys.stdin.read()
current = load_current(current_text)
merged = copy.deepcopy(current)

marketplaces = merged.get("extraKnownMarketplaces")
if not isinstance(marketplaces, dict):
    marketplaces = {}
marketplaces["prateek-local"] = desired["extraKnownMarketplaces"]["prateek-local"]
merged["extraKnownMarketplaces"] = marketplaces

enabled_plugins = merged.get("enabledPlugins")
if not isinstance(enabled_plugins, dict):
    enabled_plugins = {}
enabled_plugins = {
    name: enabled
    for name, enabled in enabled_plugins.items()
    if not name.endswith("@prateek-local")
}
enabled_plugins.update(desired["enabledPlugins"])
merged["enabledPlugins"] = enabled_plugins

merged_text = json.dumps(merged, indent=2) + "\n"
sys.stdout.write(current_text if semantic_equal(current_text, merged_text) else merged_text)
