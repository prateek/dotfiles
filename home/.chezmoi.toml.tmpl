{{- /*
  First-machine identity. machine_type is the only first-run prompt; every other
  toggle is resolved at apply time from the layered machines.toml table (see
  home/.chezmoitemplates/features.tmpl, docs/adr/0012-config-gating-convention.md,
  and docs/references/chezmoi-architecture.md). chezmoi does not load
  .chezmoidata during `chezmoi init`, so this template cannot use that resolver;
  it sets identity inline.

  Select the machine type non-interactively (the flag keys on the prompt text):
      chezmoi init --apply --promptChoice 'machine_type=work'   # any type, incl. ci
      chezmoi init --apply --promptDefaults                     # personal default only
  Call promptChoiceOnce unguarded so --promptChoice can select non-interactively;
  it errors clearly (it does not hang) when a non-interactive run gives no answer.

  Paths still resolve from env with a default; those are plumbing, not feature
  gates. To reset, delete the rendered ~/.config/chezmoi/chezmoi.toml and run
  `chezmoi init` again.
*/ -}}
{{- $dotfilesDir := env "DOTFILES_ROOT" | default (joinPath .chezmoi.homeDir "dotfiles") -}}
{{- $machineType := promptChoiceOnce . "machine_type" "machine_type" (list "personal" "homelab" "work" "ci") "personal" -}}

{{- /* The Jamf Self Service policy ID is identity (which Jamf policy elevates
       this box), not a behavior toggle, so it stays in [data]. The elevation
       method resolves to jamf-self-service on work via machines.toml, so prompt
       for the policy ID only on work. Reuse a persisted answer before prompting,
       including the legacy nested [data.elevation].jamf_policy_id so a re-init
       migrates it to the top level instead of dropping it (dig is nil-safe on a
       fresh machine). */ -}}
{{- $jamfPolicyId := or (dig "jamf_policy_id" "" .) (dig "elevation" "jamf_policy_id" "" .) -}}
{{- if and (not $jamfPolicyId) (eq $machineType "work") -}}
{{-   $jamfPolicyId = promptStringOnce . "jamf_policy_id" "Jamf Self Service policy ID for temp admin (see docs/references/jamf-self-service-elevation.md)" "" -}}
{{- end -}}

sourceDir = {{ $dotfilesDir | quote }}

# Apply scripts can prompt for sudo, so disable the pager to keep the TTY free.
pager = ""

[data]
dotfiles_dir = {{ $dotfilesDir | quote }}
xdg_config_dir = {{ (env "XDG_CONFIG_HOME" | default (joinPath .chezmoi.homeDir ".config")) | quote }}
xdg_cache_dir = {{ (env "XDG_CACHE_HOME" | default (joinPath .chezmoi.homeDir ".cache")) | quote }}
xdg_state_dir = {{ (env "XDG_STATE_HOME" | default (joinPath .chezmoi.homeDir ".local/state")) | quote }}
machine_type = {{ $machineType | quote }}
jamf_policy_id = {{ $jamfPolicyId | quote }}

# Render binary plists as XML for `chezmoi diff`. This only changes diff output.
# Apply still writes binary plists. See docs/references/chezmoi-architecture.md > Plist Management.
[[textconv]]
pattern = "**/Library/Preferences/*.plist"
command = "plutil"
args = ["-convert", "xml1", "-o", "-", "-"]

# Plist apply guards. The pre-hook reads `chezmoi status` to find managed
# plists that would change in this apply. It fails if any matching app is
# running because the app can overwrite our writes when it quits. The post-hook
# nudges cfprefsd after plist changes and can relaunch quit apps.
# Set DOTFILES_SKIP_PLIST_HOOKS=1 to skip both hooks. Sandboxed applies use it,
#   for example zsh-fresh-shells.zsh. It also force-applies over running apps
#   without killing cfprefsd.
# To relaunch quit apps after a real apply, set
#   DOTFILES_RELAUNCH_AFTER_APPLY=1.
[hooks.apply.pre]
command = "{{ $dotfilesDir }}/scripts/chezmoi-hooks/guard-running-apps.sh"

[hooks.apply.post]
command = "{{ $dotfilesDir }}/scripts/chezmoi-hooks/post-apply-plists.sh"
