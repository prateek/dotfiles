{{- /*
  First-machine settings. Values resolve in this order:
    1. Environment variable (e.g. DOTFILES_MACHINE_TYPE), used by CI and Tart
       non-interactive runs.
    2. promptStringOnce / promptBoolOnce, prompted once during chezmoi init on
       a new machine. Chezmoi saves the answer in state and reuses it on later
       applies.

  Do not write `default x (promptStringOnce ...)`. Go templates evaluate both
  arms of `default`, so the prompt fires even when the env var is set. Use
  explicit if/else to short-circuit.

  To reset, delete the rendered ~/.config/chezmoi/chezmoi.toml and run
  `chezmoi init` again.

  For toggle style choices (env|default, prompt*Once, or machine_type-derived),
  see docs/adr/0012-config-gating-convention.md.
*/ -}}
{{- $dotfilesDir := env "DOTFILES_ROOT" | default (joinPath .chezmoi.homeDir "dotfiles") -}}

{{- /* Defaults live here because chezmoi init does not load
       .chezmoidata/*.toml. Data is bound after this template renders. Keep
       the comment above as the reference. */ -}}
{{- $secretsEnabled := env "DOTFILES_SECRETS_ENABLED" -}}
{{- if not $secretsEnabled -}}
{{-   $secretsEnabled = promptBoolOnce . "secrets_enabled" "Render secret-backed files via 1Password? (change later with chezmoi edit-config or re-init)" false | toString -}}
{{- end -}}

{{- $runInstallScripts := env "DOTFILES_RUN_INSTALL_SCRIPTS" -}}
{{- if not $runInstallScripts -}}
{{-   $runInstallScripts = promptBoolOnce . "run_install_scripts" "Run install scripts (Homebrew bundle, mise, etc.) on apply?" true | toString -}}
{{- end -}}

{{- $applyDefaults := env "DOTFILES_APPLY_MACOS_DEFAULTS" -}}
{{- if not $applyDefaults -}}
{{-   $applyDefaults = promptBoolOnce . "apply_macos_defaults" "Apply macOS defaults from this repo?" true | toString -}}
{{- end -}}

{{- /* Machine type selects package groups and elevation behavior. Package
       groups are composed per machine type in
       home/.chezmoidata/packages.toml (see
       docs/adr/0010-machine-type-package-selection.md): work skips personal
       apps; `ci` is the minimal CI/Tart/audit tier (a listed prompt choice). Only
       Jamf-managed work Macs need elevation before sudo works; personal and
       homelab use the normal sudo
       prompt (see docs/references/jamf-self-service-elevation.md). */ -}}
{{- $machineType := env "DOTFILES_MACHINE_TYPE" -}}
{{- if not $machineType -}}
{{-   $machineType = promptChoiceOnce . "machine_type" "Machine type" (list "personal" "homelab" "work" "ci") "personal" -}}
{{- end -}}

{{- $elevationMethod := env "DOTFILES_ELEVATION_METHOD" -}}
{{- if not $elevationMethod -}}
{{-   if eq $machineType "work" -}}
{{-     $elevationMethod = promptStringOnce . "elevation_method" "Admin elevation method (jamf-self-service / none)" "jamf-self-service" -}}
{{-   else -}}
{{-     $elevationMethod = "none" -}}
{{-   end -}}
{{- end -}}

{{- $jamfPolicyId := env "DOTFILES_JAMF_POLICY_ID" -}}
{{- if and (not $jamfPolicyId) (eq $elevationMethod "jamf-self-service") -}}
{{-   $jamfPolicyId = promptStringOnce . "jamf_self_service_policy_id" "Jamf Self Service policy ID for temp admin (see docs/references/jamf-self-service-elevation.md)" "" -}}
{{- end -}}

sourceDir = {{ $dotfilesDir | quote }}

# Apply scripts can prompt for sudo, so disable the pager to keep the TTY free.
pager = ""

[data]
dotfiles_dir = {{ $dotfilesDir | quote }}
xdg_config_dir = {{ (env "XDG_CONFIG_HOME" | default (joinPath .chezmoi.homeDir ".config")) | quote }}
xdg_cache_dir = {{ (env "XDG_CACHE_HOME" | default (joinPath .chezmoi.homeDir ".cache")) | quote }}
xdg_state_dir = {{ (env "XDG_STATE_HOME" | default (joinPath .chezmoi.homeDir ".local/state")) | quote }}
secrets_enabled = {{ $secretsEnabled }}
run_install_scripts = {{ $runInstallScripts }}
apply_macos_defaults = {{ $applyDefaults }}
machine_type = {{ $machineType | quote }}

[data.elevation]
method = {{ $elevationMethod | quote }}
jamf_policy_id = {{ $jamfPolicyId | quote }}

# Render binary plists as XML for `chezmoi diff`. This only changes diff output.
# Apply still writes binary plists. See docs/references/chezmoi-architecture.md > Plist Management.
[[textconv]]
pattern = "**/Library/Preferences/*.plist"
command = "plutil"
args = ["-convert", "xml1", "-o", "-", "-"]

# Plist apply guards. The pre-hook reads `chezmoi status` to find managed
# plists that would change in this apply. It fails if any matching app is
# running because the app can overwrite our writes when it quits. The post-hook
# nudges cfprefsd after plist changes and can relaunch quit apps.
# Set DOTFILES_SKIP_PLIST_HOOKS=1 to skip both hooks. Sandboxed applies use it,
#   for example zsh-fresh-shells.zsh. It also force-applies over running apps
#   without killing cfprefsd.
# To relaunch quit apps after a real apply, set
#   DOTFILES_RELAUNCH_AFTER_APPLY=1.
[hooks.apply.pre]
command = "{{ $dotfilesDir }}/scripts/chezmoi-hooks/guard-running-apps.sh"

[hooks.apply.post]
command = "{{ $dotfilesDir }}/scripts/chezmoi-hooks/post-apply-plists.sh"
