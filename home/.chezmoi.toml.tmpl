{{- /*
  First-machine settings. Each value resolves with explicit short-circuit:
    1. Environment variable (e.g. DOTFILES_INSTALL_PROFILE) — for CI / Tart
       non-interactive runs.
    2. promptStringOnce / promptBoolOnce — interactive prompt the first time
       chezmoi init runs on a new machine; the answer is saved in the
       persistent state and reused on subsequent applies.

  Note: `default x (promptStringOnce ...)` is wrong — Go templates evaluate
  both arms of `default`, so the prompt would fire even when the env var is
  set. We use explicit if/else to short-circuit.

  Reset by deleting the rendered ~/.config/chezmoi/chezmoi.toml and re-running
  `chezmoi init`.
*/ -}}
{{- $dotfilesDir := env "DOTFILES_ROOT" | default (joinPath .chezmoi.homeDir "dotfiles") -}}

{{- /* Defaults inlined here because chezmoi init does not load
       .chezmoidata/*.toml (data is bound after init renders this
       template). Keep the docstring above as the canonical reference. */ -}}
{{- $profile := env "DOTFILES_INSTALL_PROFILE" -}}
{{- if not $profile -}}
{{-   $profile = promptStringOnce . "install_profile" "Install profile (core/full)" "full" -}}
{{- end -}}

{{- $secretsEnabled := env "DOTFILES_SECRETS_ENABLED" -}}
{{- if not $secretsEnabled -}}
{{-   $secretsEnabled = promptBoolOnce . "secrets_enabled" "Render secret-backed files via 1Password? (you can flip with DOTFILES_SECRETS_ENABLED=true later)" false | toString -}}
{{- end -}}

{{- $runInstallScripts := env "DOTFILES_RUN_INSTALL_SCRIPTS" -}}
{{- if not $runInstallScripts -}}
{{-   $runInstallScripts = promptBoolOnce . "run_install_scripts" "Run install scripts (Homebrew bundle, mise, etc.) on apply?" true | toString -}}
{{- end -}}

{{- $applyDefaults := env "DOTFILES_APPLY_DEFAULTS" -}}
{{- if not $applyDefaults -}}
{{-   $applyDefaults = promptBoolOnce . "apply_macos_defaults" "Apply macOS defaults from this repo?" true | toString -}}
{{- end -}}

{{- /* Machine class drives the elevation hook. Currently only Jamf-managed
       work macs need a special step before sudo works; personal/homelab fall
       through to the ordinary sudo prompt. See
       docs/jamf-self-service-elevation.md. */ -}}
{{- $machineType := env "DOTFILES_MACHINE_TYPE" -}}
{{- if not $machineType -}}
{{-   $machineType = promptChoiceOnce . "machine_type" "Machine type" (list "personal" "homelab" "work") "personal" -}}
{{- end -}}

{{- $elevationMethod := env "DOTFILES_ELEVATION_METHOD" -}}
{{- if not $elevationMethod -}}
{{-   if eq $machineType "work" -}}
{{-     $elevationMethod = promptStringOnce . "elevation_method" "Admin elevation method (jamf-self-service / none)" "jamf-self-service" -}}
{{-   else -}}
{{-     $elevationMethod = "none" -}}
{{-   end -}}
{{- end -}}

{{- $jamfPolicyId := env "DOTFILES_JAMF_POLICY_ID" -}}
{{- if and (not $jamfPolicyId) (eq $elevationMethod "jamf-self-service") -}}
{{-   $jamfPolicyId = promptStringOnce . "jamf_self_service_policy_id" "Jamf Self Service policy ID for temp admin (see docs/jamf-self-service-elevation.md)" "" -}}
{{- end -}}

{{- $installXcode := env "DOTFILES_INSTALL_XCODE" | default "false" -}}
{{- $manageZinitExternal := env "DOTFILES_MANAGE_ZINIT_EXTERNAL" | default "true" -}}

sourceDir = {{ $dotfilesDir | quote }}

# Apply scripts can prompt for sudo. Do not let a pager own the same TTY.
pager = ""

[data]
dotfiles_dir = {{ $dotfilesDir | quote }}
xdg_config_dir = {{ (env "XDG_CONFIG_HOME" | default (joinPath .chezmoi.homeDir ".config")) | quote }}
xdg_cache_dir = {{ (env "XDG_CACHE_HOME" | default (joinPath .chezmoi.homeDir ".cache")) | quote }}
xdg_state_dir = {{ (env "XDG_STATE_HOME" | default (joinPath .chezmoi.homeDir ".local/state")) | quote }}
install_profile = {{ $profile | quote }}
secrets_enabled = {{ $secretsEnabled }}
run_install_scripts = {{ $runInstallScripts }}
apply_macos_defaults = {{ $applyDefaults }}
install_xcode = {{ $installXcode }}
manage_zinit_external = {{ $manageZinitExternal }}
machine_type = {{ $machineType | quote }}

[data.elevation]
method = {{ $elevationMethod | quote }}
jamf_policy_id = {{ $jamfPolicyId | quote }}

# Render binary plists as XML for `chezmoi diff`. Affects diff output only;
# apply still writes binary. See docs/dev/chezmoi-migration-plan.md > Plist Management.
[[textconv]]
pattern = "**/Library/Preferences/*.plist"
command = "plutil"
args = ["-convert", "xml1", "-o", "-", "-"]

# Plist apply guards. The pre-hook computes which managed plists would change
# this apply (via `chezmoi status`) and refuses if any of those apps is running,
# to avoid the app overwriting our writes when it quits. The post-hook nudges
# cfprefsd if anything changed and optionally relaunches quit apps.
# Set DOTFILES_SKIP_PLIST_HOOKS=1 to short-circuit both hooks (used by
#   sandboxed applies, e.g. zsh-fresh-shells.zsh; also acts as a force-apply
#   override when you want to apply over running apps without the cfprefsd kill).
# Enable optional relaunch of quit apps after a real apply with
#   DOTFILES_RELAUNCH_AFTER_APPLY=1.
[hooks.apply.pre]
command = "{{ $dotfilesDir }}/scripts/chezmoi-hooks/guard-running-apps.sh"

[hooks.apply.post]
command = "{{ $dotfilesDir }}/scripts/chezmoi-hooks/post-apply-plists.sh"
