{{- /* acpx shortcuts gated by this machine's agent CLIs (machines.toml
       agent_clis, via features.tmpl): a shortcut is emitted only when a backing
       CLI is present. cursor-agent and codex both offer the GPT tier; the merge
       order below (cursor-agent first) lets it win the shared shortcuts.
       See docs/plans/crit-agent-bridge-plan.md. */ -}}

{{- $clis := (includeTemplate "features.tmpl" . | fromJson).agent_clis | default (list) -}}

{{- /* Shortcuts each backend provides. */ -}}
{{- $byCli := dict
    "cursor-agent" (dict
        "agpt"    (dict "command" "cursor-agent" "args" (list "--model" "gpt-5.5-high-fast" "acp"))
        "agptx"   (dict "command" "cursor-agent" "args" (list "--model" "gpt-5.5-extra-high-fast" "acp"))
        "aopus"   (dict "command" "cursor-agent" "args" (list "--model" "claude-opus-4-8-thinking-xhigh-fast" "acp"))
        "aopusx"  (dict "command" "cursor-agent" "args" (list "--model" "claude-opus-4-8-thinking-max-fast" "acp"))
        "agemini" (dict "command" "cursor-agent" "args" (list "--model" "gemini-3.1-pro" "acp")))
    "codex" (dict
        "agpt"    (dict "command" "codex-acp" "args" (list "-c" "model_reasoning_effort=high"))
        "agptx"   (dict "command" "codex-acp" "args" (list "-c" "model_reasoning_effort=xhigh")))
    "claude" (dict
        "afable"  (dict "command" "env" "args" (list "ANTHROPIC_MODEL=fable" "CLAUDE_CODE_EFFORT_LEVEL=xhigh" "claude-agent-acp"))
        "afablex" (dict "command" "env" "args" (list "ANTHROPIC_MODEL=fable" "CLAUDE_CODE_EFFORT_LEVEL=max" "claude-agent-acp")))
-}}

{{- $agents := dict -}}
{{- range $cli := list "cursor-agent" "codex" "claude" -}}
{{-   if has $cli $clis -}}{{ $agents = merge $agents (get $byCli $cli) }}{{- end -}}
{{- end -}}

{{ dict "agents" $agents | toPrettyJson }}
