#!/usr/bin/env -S uv run --quiet --script
# /// script
# requires-python = ">=3.14"
# dependencies = ["tomlkit>=0.13"]
# ///
"""Deep-merge chezmoi's desired Codex config into ~/.codex/config.toml.

Desired wins on conflicts; unrelated tables, keys, comments, and formatting
pass through untouched (preserved by tomlkit). Malformed input propagates
from `tomlkit.loads` to chezmoi. See SKILL.md and ADR 0007 for the override
model and the stale-key trade-off.
"""
import base64
import sys

import tomlkit

desired_text = base64.b64decode(
    "{{ includeTemplate "codex-config-managed.toml.tmpl" . | b64enc }}"
).decode()


def deep_merge(base, overlay):
    """Deep-merge overlay into base in place; overlay wins on conflicts.

    Recurses into any pair of mapping-like values (anything with `.items()`).
    """
    for key, value in overlay.items():
        existing = base.get(key)
        if hasattr(existing, "items") and hasattr(value, "items"):
            deep_merge(existing, value)
        else:
            base[key] = value
    return base


def semantic_equal(left: str, right: str) -> bool:
    try:
        return tomlkit.loads(left).unwrap() == tomlkit.loads(right).unwrap()
    except Exception:
        return False


current_text = sys.stdin.read()
current = tomlkit.loads(current_text) if current_text.strip() else tomlkit.document()
desired = tomlkit.loads(desired_text)
deep_merge(current, desired)

merged_text = tomlkit.dumps(current)
sys.stdout.write(current_text if semantic_equal(current_text, merged_text) else merged_text)
