#!/usr/bin/env python3
"""Merge repo-owned Codex defaults into the live config.

Codex writes machine-local trust, hook approval, NUX, and marketplace state into
config.toml on this host. Chezmoi owns stable defaults, but must preserve those
local sections when applying.
"""
import base64
import re
import sys

desired_text = base64.b64decode(
    "{{ includeTemplate "codex-config-managed.toml.tmpl" . | b64enc }}"
).decode()

managed_tables = {
    "agents",
    "mcp_servers.granola",
    "features",
    'plugins."last30days@last30days-skill"',
    "tui",
}


def is_managed_table(header: str) -> bool:
    if header in managed_tables:
        return True
    if header == "marketplaces.prateek-local":
        return True
    return re.match(r'^plugins\."[^"]+@prateek-local"$', header) is not None


def table_header(line: str) -> str | None:
    match = re.match(r"^\s*\[([^\]]+)\]\s*$", line)
    return match.group(1) if match else None


def split_toml(text: str) -> tuple[list[str], list[tuple[str, list[str]]]]:
    root: list[str] = []
    tables: list[tuple[str, list[str]]] = []
    current_header: str | None = None
    current_block: list[str] = []

    for line in text.splitlines():
        header = table_header(line)
        if header is not None:
            if current_header is not None:
                tables.append((current_header, current_block))
            current_header = header
            current_block = [line]
        elif current_header is None:
            root.append(line)
        else:
            current_block.append(line)

    if current_header is not None:
        tables.append((current_header, current_block))

    return root, tables


def key_for_line(line: str) -> str | None:
    stripped = line.strip()
    if not stripped or stripped.startswith("#") or "=" not in stripped:
        return None
    return stripped.split("=", 1)[0].strip()


def merge_root(current: list[str], desired: list[str]) -> list[str]:
    desired_key_lines = [line for line in desired if key_for_line(line)]
    desired_keys = {key_for_line(line) for line in desired_key_lines}
    preserved = [
        line
        for line in current
        if key_for_line(line) is None or key_for_line(line) not in desired_keys
    ]

    merged = desired_key_lines[:]
    if preserved:
        if merged and preserved[0].strip():
            merged.append("")
        merged.extend(preserved)
    return trim_trailing_blanks(merged)


def trim_trailing_blanks(lines: list[str]) -> list[str]:
    while lines and not lines[-1].strip():
        lines.pop()
    return lines


def toml_equal(left: str, right: str) -> bool:
    try:
        import tomllib
    except ModuleNotFoundError:
        try:
            import tomli as tomllib
        except ModuleNotFoundError:
            return False

    try:
        return tomllib.loads(left) == tomllib.loads(right)
    except Exception:
        return False


current_text = sys.stdin.read()
current_root, current_tables = split_toml(current_text)
desired_root, desired_tables = split_toml(desired_text)

desired_table_map: dict[str, list[str]] = {}
desired_table_order: list[str] = []
for header, block in desired_tables:
    desired_table_map[header] = trim_trailing_blanks(block[:])
    desired_table_order.append(header)

output: list[str] = []
output.extend(merge_root(current_root, desired_root))

for header in desired_table_order:
    if not is_managed_table(header):
        continue
    if output:
        output.append("")
    output.extend(desired_table_map[header])

for header, block in current_tables:
    if is_managed_table(header):
        continue
    if output:
        output.append("")
    output.extend(trim_trailing_blanks(block[:]))

merged_text = "\n".join(trim_trailing_blanks(output)) + "\n"
sys.stdout.write(current_text if toml_equal(current_text, merged_text) else merged_text)
