{{- /*
  brewfile.tmpl — Homebrew Bundle input rendered from .packages data.

  Machine-type selection: env DOTFILES_MACHINE_TYPE > chezmoi data
  .machine_type (set by the inited config; may be absent when this template
  is rendered against a worktree without the user's config) >
  .packages.default_machine_type.

  A machine type composes reusable groups (.packages.machine_types.<type>.groups).
  Each Brewfile section (tap/brew/cask/mas) is the UNION of that section across
  the selected groups, deduped by name (group order, then item order, first
  occurrence wins).

  MAS opt-in: gated by env DOTFILES_INSTALL_MAS_APPS=true|1|yes|on.

  Output shape: lines per section (tap, brew, cask, optionally mas), with
  a single blank line separating non-empty sections, and exactly one
  trailing newline at the end. This matches the format brew bundle parses.

  Optional fields on items (url on tap, link/args on brew, link/args/appdir
  on cask) are accessed via `dig` so missing keys do not error — Go
  templates fail strictly on `.foo` against a map without "foo".
*/ -}}
{{- $root := . -}}
{{- $machineType := coalesce (env "DOTFILES_MACHINE_TYPE") (dig "machine_type" "" .) .packages.default_machine_type -}}
{{- if not (hasKey .packages.machine_types $machineType) -}}
{{-   fail (printf "brewfile.tmpl: unknown machine type %q (available: %v)" $machineType (keys .packages.machine_types)) -}}
{{- end -}}
{{- $groups := (index .packages.machine_types $machineType).groups -}}
{{- $masOptIn := env "DOTFILES_INSTALL_MAS_APPS" | lower -}}
{{- $includeMas := has $masOptIn (list "1" "true" "yes" "on") -}}

{{- /* Union every section across the selected groups in a single pass. */ -}}
{{- $taps := list -}}{{- $tapSeen := list -}}
{{- $brews := list -}}{{- $brewSeen := list -}}
{{- $casks := list -}}{{- $caskSeen := list -}}
{{- $mas := list -}}{{- $masSeen := list -}}
{{- range $gname := $groups -}}
{{-   if not (hasKey $root.packages.groups $gname) -}}{{- fail (printf "brewfile.tmpl: machine type %q references undefined group %q" $machineType $gname) -}}{{- end -}}
{{-   $g := index $root.packages.groups $gname -}}
{{-   range default (list) (dig "taps" (list) $g) -}}
{{-     if not (has .name $tapSeen) -}}{{- $taps = mustAppend $taps . -}}{{- $tapSeen = mustAppend $tapSeen .name -}}{{- end -}}
{{-   end -}}
{{-   range default (list) (dig "brews" (list) $g) -}}
{{-     if not (has .name $brewSeen) -}}{{- $brews = mustAppend $brews . -}}{{- $brewSeen = mustAppend $brewSeen .name -}}{{- end -}}
{{-   end -}}
{{-   range default (list) (dig "casks" (list) $g) -}}
{{-     if not (has .name $caskSeen) -}}{{- $casks = mustAppend $casks . -}}{{- $caskSeen = mustAppend $caskSeen .name -}}{{- end -}}
{{-   end -}}
{{-   range default (list) (dig "mas" (list) $g) -}}
{{-     if not (has .name $masSeen) -}}{{- $mas = mustAppend $mas . -}}{{- $masSeen = mustAppend $masSeen .name -}}{{- end -}}
{{-   end -}}
{{- end -}}

{{- $tapLines := list -}}
{{- range $taps -}}
{{-   $url := dig "url" "" . -}}
{{-   if $url -}}
{{-     $tapLines = mustAppend $tapLines (printf "tap %q, %q" .name $url) -}}
{{-   else -}}
{{-     $tapLines = mustAppend $tapLines (printf "tap %q" .name) -}}
{{-   end -}}
{{- end -}}

{{- $brewLines := list -}}
{{- range $brews -}}
{{-   $line := printf "brew %q" .name -}}
{{-   if hasKey . "link" -}}
{{-     $line = printf "%s, link: %t" $line .link -}}
{{-   end -}}
{{-   $args := dig "args" (list) . -}}
{{-   if $args -}}
{{-     $quoted := list -}}
{{-     range $args -}}{{- $quoted = mustAppend $quoted (printf "%q" .) -}}{{- end -}}
{{-     $line = printf "%s, args: [%s]" $line (join ", " $quoted) -}}
{{-   end -}}
{{-   $parts := splitList "/" .name -}}
{{-   if and (eq (len $parts) 3) (ne (index $parts 0) "homebrew") -}}
{{-     $line = printf "%s, trusted: true" $line -}}
{{-   end -}}
{{-   $brewLines = mustAppend $brewLines $line -}}
{{- end -}}

{{- $caskLines := list -}}
{{- range $casks -}}
{{-   $line := printf "cask %q" .name -}}
{{-   if hasKey . "link" -}}
{{-     $line = printf "%s, link: %t" $line .link -}}
{{-   end -}}
{{-   $args := dig "args" (list) . -}}
{{-   if $args -}}
{{-     $quoted := list -}}
{{-     range $args -}}{{- $quoted = mustAppend $quoted (printf "%q" .) -}}{{- end -}}
{{-     $line = printf "%s, args: [%s]" $line (join ", " $quoted) -}}
{{-   end -}}
{{-   $appdir := dig "appdir" "" . -}}
{{-   if $appdir -}}
{{-     $line = printf "%s, args: { appdir: %q }" $line $appdir -}}
{{-   end -}}
{{-   $parts := splitList "/" .name -}}
{{-   if and (eq (len $parts) 3) (ne (index $parts 0) "homebrew") -}}
{{-     $line = printf "%s, trusted: true" $line -}}
{{-   end -}}
{{-   $caskLines = mustAppend $caskLines $line -}}
{{- end -}}

{{- $masLines := list -}}
{{- if $includeMas -}}
{{-   range $mas -}}
{{-     $masLines = mustAppend $masLines (printf "mas %q, id: %d" .name (int .id)) -}}
{{-   end -}}
{{- end -}}

{{- /* Assemble non-empty sections separated by blank lines. */ -}}
{{- $sections := list -}}
{{- if $tapLines -}}{{- $sections = mustAppend $sections (join "\n" $tapLines) -}}{{- end -}}
{{- if $brewLines -}}{{- $sections = mustAppend $sections (join "\n" $brewLines) -}}{{- end -}}
{{- if $caskLines -}}{{- $sections = mustAppend $sections (join "\n" $caskLines) -}}{{- end -}}
{{- if $masLines -}}{{- $sections = mustAppend $sections (join "\n" $masLines) -}}{{- end -}}
{{ join "\n\n" $sections }}
