###############################################################################
# Inline plists (nested settings that don't round-trip via `defaults write`)  #
###############################################################################

# Disable system keyboard shortcuts that conflict with Raycast/BTT/Hammerspoon.
# IDs map to actions in System Settings → Keyboard → Keyboard Shortcuts:
#   18, 26  — Mission Control / dictation chord variants
#   28-31   — Spotlight / show desktop variants
#   64, 65  — show launchpad / dock
#   164     — fn-key behavior toggle
#   184     — show dictionary
DISABLED_HOTKEY_IDS=(18 26 28 29 30 31 64 65 164 184)
HOTKEYS_PLIST="$HOME/Library/Preferences/com.apple.symbolichotkeys.plist"
/usr/libexec/PlistBuddy -c "Add :AppleSymbolicHotKeys dict" "$HOTKEYS_PLIST" 2>/dev/null || true
for id in "${DISABLED_HOTKEY_IDS[@]}"; do
	/usr/libexec/PlistBuddy -c "Delete :AppleSymbolicHotKeys:$id" "$HOTKEYS_PLIST" 2>/dev/null || true
	/usr/libexec/PlistBuddy \
		-c "Add :AppleSymbolicHotKeys:$id dict" \
		-c "Add :AppleSymbolicHotKeys:$id:enabled bool false" \
		"$HOTKEYS_PLIST"
done

