	OpenWith -bool true \
	Privileges -bool true

# Icon-view geometry. Finder mirrors the same settings under three parent
# keys; one PlistBuddy invocation does all of them.
icon_cmds=()
for parent in DesktopViewSettings FK_StandardViewSettings StandardViewSettings; do
	icon_cmds+=(
		-c "Set :${parent}:IconViewSettings:showItemInfo true"
		-c "Set :${parent}:IconViewSettings:arrangeBy grid"
		-c "Set :${parent}:IconViewSettings:gridSpacing 54"
		-c "Set :${parent}:IconViewSettings:iconSize 64"
	)
done
icon_cmds+=(-c "Set DesktopViewSettings:IconViewSettings:labelOnBottom false")
/usr/libexec/PlistBuddy "${icon_cmds[@]}" ~/Library/Preferences/com.apple.finder.plist 2>/dev/null || true

