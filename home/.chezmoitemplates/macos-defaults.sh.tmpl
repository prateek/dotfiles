# modules ship; default them off so we don't auto-adopt new menu icons.
for i in {0..12}; do
	defaults write com.apple.controlcenter "NSStatusItem Visible Item-$i" -bool false
done

sudo defaults write /Library/Preferences/com.apple.loginwindow AdminHostInfo HostName

###############################################################################
# Input — keyboard, trackpad, mouse, Bluetooth                                #
###############################################################################

# Tap-to-click — written four times because each scope is read by a
# different consumer (built-in trackpad, Bluetooth trackpad, login screen
# via -currentHost, user session via global).
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true
defaults -currentHost write NSGlobalDomain com.apple.mouse.tapBehavior -int 1
defaults write NSGlobalDomain com.apple.mouse.tapBehavior -int 1

# Default three-finger tap is "Look up" (value 2) which fires on brushes.
defaults write com.apple.AppleMultitouchTrackpad TrackpadThreeFingerTapGesture -int 0
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadThreeFingerTapGesture -int 0

defaults write NSGlobalDomain com.apple.swipescrolldirection -bool false

# Ctrl + scroll = zoom (mask 262144 = 1<<18, the Ctrl modifier bit).
run_optional_defaults_group "Universal Access defaults" write_universal_access_defaults

defaults write com.apple.BluetoothAudioAgent "Apple Bitpool Min (editable)" -int 40

defaults write NSGlobalDomain AppleKeyboardUIMode -int 3

# Fastest values the OS accepts (1 = ~30ms repeat, 12 = ~180ms initial).
defaults write NSGlobalDomain KeyRepeat -int 1
defaults write NSGlobalDomain InitialKeyRepeat -int 12

# Music app's media-key hijack.
launchctl unload -w /System/Library/LaunchAgents/com.apple.rcd.plist 2>/dev/null

