# macOS system preferences. Run on a fresh Mac (or after a macOS upgrade)
# to converge to the configured state. Idempotent — safe to re-run.
#
# Methodology for keeping this in sync with reality:
#
# 1. To find new settings worth pinning: change them in System Settings,
#    then `defaults read <domain>` (or `log stream --predicate
#    'process == "cfprefsd"'` while toggling) to see which keys move.
# 2. To detect drift between this script and your current Mac: capture a
#    factory baseline from a clean Tart VM (`ghcr.io/cirruslabs/
#    macos-<version>-base:latest`), snapshot the laptop the same way
#    (`defaults read` over every domain in `defaults domains`), then diff.
#    Filter to a whitelist of domains you care about (Dock, Finder,
#    Control Center, NSGlobalDomain, WindowManager, symbolichotkeys,
#    trackpad/mouse). The diff is a checklist — translate keys with
#    nested dicts (symbolichotkeys, HIToolbox) by hand.
# 3. Things `defaults` cannot capture and that need manual re-grant on a
#    new Mac: TCC permissions (privacy/accessibility/screen recording),
#    Focus modes, Shortcuts.app, Stage Manager window layouts, sandboxed
#    app prefs in ~/Library/Containers, SMAppService login items.

# Close System Settings so it doesn't overwrite changes mid-run.
osascript -e 'tell application "System Settings" to quit' 2>/dev/null || true
osascript -e 'tell application "System Preferences" to quit' 2>/dev/null || true

###############################################################################
# Helpers                                                                     #
###############################################################################

warn() {
	printf '[dotfiles] warning: %s\n' "$*" >&2
}

# Filter the InternetServices.m noise `systemsetup` emits on every invocation.
systemsetup_set() {
	local err rc
	err="$(mktemp)"
	if sudo systemsetup "$@" 2>"$err"; then rc=0; else rc=$?; fi
	if [ -s "$err" ]; then
		grep -vE '### Error:-99 File:.*/InternetServices.m Line:[0-9]+' "$err" >&2 || true
	fi
	rm -f "$err"
	return "$rc"
}

run_optional_defaults_group() {
	local err label message rc

	label="$1"
	shift

	err="$(mktemp)"
	if "$@" 2>"$err"; then rc=0; else rc=$?; fi
	if [ "$rc" -ne 0 ]; then
		message="$(sed -n '1p' "$err")"
		case "$message" in
			*"Could not write domain "*)
				warn "$label skipped; defaults domain is unavailable on this host."
				;;
			*)
				warn "$label skipped: ${message:-exit $rc}"
				;;
		esac
	fi
	rm -f "$err"
	return 0
}

# For nested-dict domains (input sources, hotkey values) that don't
# round-trip through `defaults write`.
import_inline_plist() {
	local domain="$1"
	local dir
	dir="$(mktemp -d)"
	cat >"$dir/import.plist"
	defaults import "$domain" "$dir/import.plist"
	rm -rf "$dir"
}

write_universal_access_defaults() {
	local rc=0

	defaults write com.apple.universalaccess closeViewScrollWheelToggle -bool true || rc=1
	defaults write com.apple.universalaccess HIDScrollZoomModifierMask -int 262144 || rc=1
	defaults write com.apple.universalaccess closeViewZoomFollowsFocus -bool true || rc=1
	defaults write com.apple.universalaccess reduceTransparency -bool true || rc=1

	return "$rc"
}

write_safari_defaults() {
	local rc=0

	mkdir -p "$HOME/Library/Containers/com.apple.Safari/Data/Library/Preferences" || rc=1

	defaults write com.apple.Safari UniversalSearchEnabled -bool false || rc=1
	defaults write com.apple.Safari SuppressSearchSuggestions -bool true || rc=1

	defaults write com.apple.Safari WebKitTabToLinksPreferenceKey -bool true || rc=1
	defaults write com.apple.Safari com.apple.Safari.ContentPageGroupIdentifier.WebKit2TabsToLinks -bool true || rc=1

	defaults write com.apple.Safari ShowFullURLInSmartSearchField -bool true || rc=1
	defaults write com.apple.Safari HomePage -string "about:blank" || rc=1
	defaults write com.apple.Safari AutoOpenSafeDownloads -bool false || rc=1
	defaults write com.apple.Safari com.apple.Safari.ContentPageGroupIdentifier.WebKit2BackspaceKeyNavigationEnabled -bool true || rc=1
	defaults write com.apple.Safari ShowFavoritesBar -bool false || rc=1
	defaults write com.apple.Safari ShowSidebarInTopSites -bool false || rc=1
	defaults write com.apple.Safari FindOnPageMatchesWordStartsOnly -bool false || rc=1

	defaults write com.apple.Safari IncludeDevelopMenu -bool true || rc=1
	defaults write com.apple.Safari WebKitDeveloperExtrasEnabledPreferenceKey -bool true || rc=1
	defaults write com.apple.Safari com.apple.Safari.ContentPageGroupIdentifier.WebKit2DeveloperExtrasEnabled -bool true || rc=1

	defaults write com.apple.Safari WebContinuousSpellCheckingEnabled -bool true || rc=1
	defaults write com.apple.Safari AutoFillFromAddressBook -bool false || rc=1
	defaults write com.apple.Safari AutoFillPasswords -bool false || rc=1
	defaults write com.apple.Safari AutoFillCreditCardData -bool false || rc=1
	defaults write com.apple.Safari AutoFillMiscellaneousForms -bool false || rc=1

	defaults write com.apple.Safari WebKitJavaScriptCanOpenWindowsAutomatically -bool false || rc=1
	defaults write com.apple.Safari com.apple.Safari.ContentPageGroupIdentifier.WebKit2JavaScriptCanOpenWindowsAutomatically -bool false || rc=1
	defaults write com.apple.Safari SendDoNotTrackHTTPHeader -bool true || rc=1
	defaults write com.apple.Safari InstallExtensionUpdatesAutomatically -bool true || rc=1

	return "$rc"
}

###############################################################################
# Boot, power, sleep                                                          #
###############################################################################

sudo nvram SystemAudioVolume=" "
sudo pmset -a standbydelay 86400
sudo pmset -a hibernatemode 0
systemsetup_set -setrestartfreeze on

if ! pmset -g batt 2>/dev/null | grep -q "InternalBattery"; then
	sudo pmset -a sleep 0 standby 0 autopoweroff 0 > /dev/null 2>&1 || true
fi

# HiDPI requires a restart to take effect.
sudo defaults write /Library/Preferences/com.apple.windowserver DisplayResolutionEnabled -bool true

