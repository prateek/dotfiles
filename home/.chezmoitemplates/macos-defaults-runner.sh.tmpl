{{ $root := .root -}}
{{ $defaultsHash := .defaultsHash -}}
{{ $snapshotHelper := .snapshotHelper -}}
{{ $forceMacosDefaults := .forceMacosDefaults -}}
if [ "$(uname -s)" != "Darwin" ]; then
  log "macOS defaults skipped on non-macOS host."
  exit 0
fi

# The defaults body lives in home/.chezmoitemplates/macos-defaults.sh.tmpl.
# The rendered run_onchange wrapper changes when the desired defaults payload or
# snapshot helper changes. Active macOS state is checked at runtime before
# entering the imperative defaults body.
#
# Idempotent: writing the same defaults value is a no-op at cfprefsd.
#
# Skip flags honoured by the defaults template (set in env before chezmoi apply):
#   DOTFILES_SKIP_LSREGISTER=1     skip the slow Open With rebuild
#   DOTFILES_SKIP_REINDEX=1        skip Spotlight full reindex (sudo)
#   DOTFILES_SKIP_APP_RESTART=1    don't killall Dock/Finder/Safari/...
#
# Sudo behaviour: the chezmoi script library starts the shared keepalive
# before running the defaults body. The defaults template does not maintain its
# own sudo session.

defaults_hash={{ $defaultsHash | quote }}
snapshot_helper={{ $snapshotHelper | quote }}
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles"
state_file="$state_dir/macos-defaults.state"
force_macos_defaults={{ if $forceMacosDefaults }}1{{ else }}0{{ end }}

macos_defaults_snapshot_hash() {
  [ -x "$snapshot_helper" ] || die "macOS defaults snapshot helper missing: $snapshot_helper"
  if have shasum; then
    "$snapshot_helper" "$defaults_hash" | shasum -a 256 | awk '{print $1}'
  elif have openssl; then
    "$snapshot_helper" "$defaults_hash" | openssl dgst -sha256 | awk '{print $NF}'
  else
    "$snapshot_helper" "$defaults_hash" | cksum | awk '{print $1 "-" $2}'
  fi
}

current_state="$(printf 'payload=%s\nsnapshot=%s\n' "$defaults_hash" "$(macos_defaults_snapshot_hash)")"
if [ "$force_macos_defaults" != "1" ] \
  && [ -r "$state_file" ] \
  && [ "$(cat "$state_file" 2>/dev/null || true)" = "$current_state" ]; then
  log "macOS defaults already applied for this desired state; skipping."
  exit 0
fi

dotfiles_sudo_start "macOS defaults need administrator access. Enter your macOS password if prompted."
{{ template "macos-defaults.sh.tmpl" $root }}
mkdir -p "$state_dir"
printf 'payload=%s\nsnapshot=%s\n' "$defaults_hash" "$(macos_defaults_snapshot_hash)" >"$state_file"
