# shellcheck shell=sh
# Generated by chezmoi. The elevation method is resolved from machines.toml
# (features.tmpl); the Jamf policy ID is identity from [data].jamf_policy_id.
# Sourced by dotfiles_admin_elevate in home/.chezmoitemplates/script_lib.sh.
# Override per shell with the matching DOTFILES_* env var; change the persistent
# method via a machines.toml layer (or [data].machines_local), and the policy ID
# by re-running `chezmoi init` or editing ~/.config/chezmoi/chezmoi.toml.
#
# jamf_policy_id is identity in [data]; some configs nest it under
# [data.elevation] instead, so read the top-level key and fall back to the
# legacy nested path.

: "${DOTFILES_ELEVATION_METHOD:={{ (includeTemplate "features.tmpl" . | fromJson).elevation }}}"
: "${DOTFILES_JAMF_POLICY_ID:={{ or (dig "jamf_policy_id" "" .) (dig "elevation" "jamf_policy_id" "" .) }}}"
