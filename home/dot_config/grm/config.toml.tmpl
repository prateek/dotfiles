# Generated by chezmoi from base + machine-type fragments. DO NOT EDIT BY HAND.
# Edit home/.chezmoiassets/grm/{base,<machine_type>}.toml, or (machine_type=work)
# ~/.config/grm/config.local.toml, or run `grmrepo refresh`; then `chezmoi apply`.

{{ include ".chezmoiassets/grm/base.toml" }}
{{- if eq .machine_type "work" }}
{{- $local := joinPath .chezmoi.homeDir ".config/grm/config.local.toml" }}
{{- if stat $local }}
{{ output "cat" $local }}
{{- end }}
{{- else if or (eq .machine_type "personal") (eq .machine_type "homelab") }}
{{ include (printf ".chezmoiassets/grm/%s.toml" .machine_type) }}
{{- end }}
