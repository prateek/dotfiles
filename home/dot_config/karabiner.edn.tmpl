;; Karabiner-Elements config, authored in Goku EDN and compiled to
;; ~/.config/karabiner/karabiner.json by `goku` at `chezmoi apply` time
;; (see run_onchange_after_45-karabiner-goku). Edit THIS file, never the JSON.
;;
;; NOTE to future agents: don't guess goku or Karabiner syntax/behavior from memory — use
;; the `ask` skill against the real sources. `ask src github:yqrashawn/GokuRakuJoudo@master`
;; for goku internals (e.g. :condi in-rule conditions, simlayers, :set/:noti/:mkey to-event
;; shortcuts — features the tutorial omits), and the Karabiner docs at
;; karabiner-elements.pqrs.org for manipulator semantics like mouse_key wheel signs. When in
;; doubt, compile with `goku --dry-run-all` and diff the JSON before/after.
;;
;; 8BitDo Zero 2 (keyboard mode), held rotated 90° left so the A button points up.
;; Start toggles a sticky mouse layer (press once to enter — shows a "🖱 Mouse mode"
;; notification — press again to exit). The pad emits letter keycodes; the only templated
;; value is the dictation path.
;;
;; Each :rules block opens with a [:condi …] marker — a Goku in-rule condition that gets
;; merged into every following rule in that block (and reset at the block's end). So the
;; device scope (:zero2) and the layer gate (:pad_mouse_mode) are stated once per block
;; instead of on every rule.
;;
;; Buttons -> emitted keycode (controller's native orientation; rotate 90° left to hold):
;;
;;     [L] k                                       m [R]
;;     ─────────────────────────────────────────────────
;;
;;             (f) Up                      (h) X
;;     (c) Left      (d) Right         (i) Y     (g) A
;;             (e) Down                    (j) B
;;
;;                  (n) Select   (o) Start
;;
;;           └──── D-PAD ────┘        └──── FACE ────┘
;;
;; Overlays in priority order — Karabiner takes the first matching manipulator. The mouse
;; overlay (gated on pad_mouse_mode) is listed FIRST so it wins when the toggle is on. Next
;; come the per-app overlays (each gated on a frontmost app), so their bumper remaps beat the
;; base layer but still yield to mouse mode. The base layer is the unconditional default and
;; falls through last. Held rotated, the face diamond reads A=up, B=right, Y=down, X=left:
;;
;;   key        base layer (default)          mouse layer (toggle on)
;;   ─────────  ───────────────────────────   ────────────────────────
;;   f  D-up    ↑ arrow                        scroll up
;;   e  D-down  ↓ arrow                        scroll down
;;   c  D-left  ← arrow                        scroll left
;;   d  D-right → arrow                        scroll right
;;   g  A       dictation (sidekick + F19)     move cursor up
;;   j  B       return / enter                 move cursor right
;;   i  Y       escape                         move cursor down
;;   h  X       delete / backspace             move cursor left
;;   m  R       —                              left click  (button1)
;;   k  L       —                              right click (button2)
;;   n  Select  —                              —
;;   o  Start   toggle on (🖱 notification)    toggle off
;;
;; Per-app overlays (frontmost app, mouse toggle off) remap just the two bumpers, keeping R =
;; "previous" and L = "next" (R sits above L when held):
;;
;;   app   R bumper (m)            L bumper (k)
;;   ────  ─────────────────────   ─────────────────
;;   Orca  ⌘⇧↑ previous worktree   ⌘⇧↓ next worktree
;;   Arc   ⌘⇧[ previous tab        ⌘⇧] next tab

{:devices {:zero2    [{:vendor_id 11720 :product_id 36888}]
           :internal [{:is_built_in_keyboard true}]}

 :applications {:orca ["^com\\.stablyai\\.orca$"]
                :arc  ["^company\\.thebrowser\\.Browser$"]}

 :main
 [{:des "8BitDo: Start toggles the mouse layer (with notification)"
   :rules [[:condi :zero2]
           [:o [{:set ["pad_mouse_mode" 0]} {:noti {:id :pad_mouse_mode :text ""}}]              :pad_mouse_mode]
           [:o [{:set ["pad_mouse_mode" 1]} {:noti {:id :pad_mouse_mode :text "🖱 Mouse mode"}}] :!pad_mouse_mode]]}

  {:des "8BitDo mouse overlay (toggle on): d-pad scrolls, face moves cursor, R/L click"
   :rules [[:condi :zero2 :pad_mouse_mode]
           [:f {:mkey {:vwheel -40}}]
           [:e {:mkey {:vwheel 40}}]
           [:c {:mkey {:hwheel 40}}]
           [:d {:mkey {:hwheel -40}}]
           [:g {:mkey {:y -1536}}]
           [:j {:mkey {:x 1536}}]
           [:i {:mkey {:y 1536}}]
           [:h {:mkey {:x -1536}}]
           [:m {:pkey :button1}]
           [:k {:pkey :button2}]]}

  {:des "8BitDo Orca overlay (base layer, Orca frontmost): bumpers navigate worktrees"
   :rules [[:condi :zero2 :orca]
           [:m {:key :up_arrow   :modi [:left_command :left_shift]}]
           [:k {:key :down_arrow :modi [:left_command :left_shift]}]]}

  {:des "8BitDo Arc overlay (base layer, Arc frontmost): bumpers switch tabs"
   :rules [[:condi :zero2 :arc]
           [:m {:key :open_bracket  :modi [:left_command :left_shift]}]
           [:k {:key :close_bracket :modi [:left_command :left_shift]}]]}

  {:des "8BitDo base layer (default): d-pad arrows, A dictation, X bksp, B enter, Y esc"
   :rules [[:condi :zero2]
           [:f :up_arrow]
           [:e :down_arrow]
           [:c :left_arrow]
           [:d :right_arrow]
           [:g [{:shell "{{ .chezmoi.homeDir }}/.local/bin/dictation-sidekick"} :f19]]
           [:j :return_or_enter]
           [:i :escape]
           [:h :delete_or_backspace]
           [:m :vk_none]
           [:k :vk_none]
           [:n :vk_none]]}

  {:des "Apple internal: modifier remaps"
   :rules [[:##caps_lock    :left_control [:internal] {:alone :escape}]
           [:##fn           :left_option  [:internal]]
           [:##left_control {:key :left_shift :modi [:left_control :left_option] :lazy true}
            [:internal] {:alone :f19 :params {:alone 200}}]
           [:##left_option  {:key :left_shift :modi [:left_command :left_control :left_option] :lazy true}
            [:internal]]]}]}
