function setup_for_ralph() {
  emulate -L zsh

  local cwd
  cwd="$(pwd)"

  local porcelain
  local implementation_log
  implementation_log="IMPLEMENTATION_LOG.md"

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    print -u2 -- "setup_for_ralph: error: not a git repository: ${cwd}"
    return 1
  fi

  porcelain="$(git status --porcelain --untracked-files=all)"
  if [[ -n "${porcelain}" ]]; then
    print -u2 -- "setup_for_ralph: error: git repo must be clean (no staged/unstaged/untracked files)"
    print -u2 -- "setup_for_ralph: error: run 'git status' to inspect"
    return 1
  fi

  if [[ ! -f "PRD.md" ]]; then
    print -u2 -- "setup_for_ralph: error: PRD.md not found in ${cwd}"
    return 1
  fi

  if grep -qE '^##[[:space:]]+Implementation Updates([[:space:]]|$)' PRD.md; then
    print -u2 -- "setup_for_ralph: warning: PRD.md starts with an implementation log section"
    print -u2 -- "setup_for_ralph: warning: keep PRD.md stable and move iteration updates to ${implementation_log}"
  fi

  if ! grep -qE '^###[[:space:]]+(Current Blockers|Critical Path)([[:space:]]|$)|^##[[:space:]]+(Current Blockers|Critical Path)([[:space:]]|$)' PRD.md; then
    print -u2 -- "setup_for_ralph: warning: PRD.md does not define an ordered 'Current Blockers' or 'Critical Path' section"
    print -u2 -- "setup_for_ralph: warning: the loop will work better if PRD.md makes the first functional slice and its blockers explicit"
  fi

  if [[ -f "progress.md" ]]; then
    print -u2 -- "setup_for_ralph: warning: progress.md is legacy and ignored by the generated loop"
    print -u2 -- "setup_for_ralph: warning: use ${implementation_log} as the only implementation journal"
  fi

  if [[ ! -f ".gitignore" ]]; then
    print -r -- ".logs/" > .gitignore
  elif ! grep -qF ".logs/" .gitignore; then
    print -r -- "" >> .gitignore
    print -r -- ".logs/" >> .gitignore
  fi

  cat > ralph-loop.sh <<'RALPH_LOOP_EOF'
#!/bin/bash
set -e

# adapted from: https://gist.github.com/prateek/14fae59c71921710a3e055d74f30c8af
if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <iterations>"
  exit 1
fi

if ! [[ "$1" =~ ^[0-9]+$ ]] || [[ "$1" -lt 1 ]]; then
  echo "Iterations must be a positive integer"
  exit 1
fi

PROMISE_FILE="I_PROMISE_ALL_TASKS_IN_THE_PRD_ARE_DONE_I_AM_NOT_LYING_I_SWEAR"

mkdir -p .logs
rm -f "$PROMISE_FILE"

for ((i = 1; i <= $1; i++)); do
  codex --dangerously-bypass-approvals-and-sandbox exec <<'EOF' 2>&1 | tee -a ".logs/iterations.log"
1. Read PRD.md, AGENTS.md, and IMPLEMENTATION_LOG.md if it exists.
2. Use PRD.md as the product contract. Treat a 'Current Blockers' or 'Critical Path' section as the primary task-selection source.
3. Identify the earliest unfinished blocker for the first unfinished functional vertical slice, and implement exactly one task that advances that slice.
4. Run your tests and type checks.
5. Append the completed slice, checks run, and newly discovered follow-up work to IMPLEMENTATION_LOG.md.
6. Commit your changes.

Rules:
- Do not use recency in PRD.md or IMPLEMENTATION_LOG.md as a priority signal.
- Do not rewrite PRD.md as an implementation log.
- Only edit PRD.md when the product spec itself must change.
- IMPLEMENTATION_LOG.md is context and execution history, not the priority oracle.
- Isolated seam work is allowed only when it directly unblocks the current functional slice.
- Later lifecycle polish, helper seams, trace expansion, or fidelity cleanup cannot outrank unfinished blockers for the first native slice.
- Ignore progress.md if it exists; use IMPLEMENTATION_LOG.md as the only implementation journal.
ONLY WORK ON A SINGLE TASK.

If all blockers and acceptance criteria in the PRD are complete, and there are no unfinished tasks left, then and only then touch a file named I_PROMISE_ALL_TASKS_IN_THE_PRD_ARE_DONE_I_AM_NOT_LYING_I_SWEAR. Otherwise respond with a brief summary of changes and remaining blockers.
EOF

  if [[ -f "$PROMISE_FILE" ]]; then
    echo "PRD complete after $i iterations."
    exit 0
  fi
done

echo "PRD not complete after $1 iterations."
exit 1
RALPH_LOOP_EOF

  chmod +x ralph-loop.sh

  if [[ ! -f "${implementation_log}" ]]; then
    cat > "${implementation_log}" <<EOF
# Implementation Log

This file is the implementation journal for this repo.
Task priority comes from \`PRD.md\` blockers and critical path ordering, not recency in this log.

## $(date '+%Y-%m-%d %H:%M')

- initial Ralph loop setup
EOF
  fi

  porcelain="$(git status --porcelain --untracked-files=all)"
  if [[ -n "${porcelain}" ]]; then
    git add -A
    git commit -m "chore: ralph setup"
  fi

  print -- "setup_for_ralph: success"
}

setup_for_ralph "$@"
