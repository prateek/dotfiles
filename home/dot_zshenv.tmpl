#!/usr/bin/env zsh
# vim:syntax=zsh
# vim:filetype=zsh

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

export DOTFILES="${DOTFILES:-{{ .dotfiles_dir }}}"
export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"
export ZSHCONFIG="${ZSHCONFIG:-$ZDOTDIR}"

# ZDOTDIR-unset shells only read THIS file, so hand off to the real per-shell env.
[[ "$ZDOTDIR/.zshenv" != "$HOME/.zshenv" && -r "$ZDOTDIR/.zshenv" ]] && source "$ZDOTDIR/.zshenv"
