#!/usr/bin/env python3
"""Merge Chrome/Perfetto trace JSON files."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--output", required=True, help="Merged trace output path")
    parser.add_argument("traces", nargs="+", help="Trace JSON files to merge")
    return parser.parse_args()


def load_events(path: Path) -> list[dict[str, Any]]:
    if not path.exists():
        raise FileNotFoundError(f"trace file not found: {path}")
    if not path.is_file():
        raise ValueError(f"trace path is not a file: {path}")
    data = json.loads(path.read_text(encoding="utf-8"))
    events = data.get("traceEvents", [])
    if not isinstance(events, list):
        raise ValueError(f"{path} does not contain a traceEvents list")
    return [event for event in events if isinstance(event, dict)]


def sort_key(event: dict[str, Any]) -> tuple[int, int, int, str]:
    ts = event.get("ts")
    if not isinstance(ts, int):
        ts = -1
    pid = event.get("pid")
    if not isinstance(pid, int):
        pid = 0
    tid = event.get("tid")
    if not isinstance(tid, int):
        tid = 0
    name = event.get("name")
    if not isinstance(name, str):
        name = ""
    return ts, pid, tid, name


def main() -> int:
    args = parse_args()
    events: list[dict[str, Any]] = []
    try:
        for trace in args.traces:
            events.extend(load_events(Path(trace)))
    except (FileNotFoundError, ValueError, json.JSONDecodeError) as error:
        print(f"merge-perfetto: {error}", file=sys.stderr)
        return 1

    events.sort(key=sort_key)

    output = Path(args.output)
    output.parent.mkdir(parents=True, exist_ok=True)
    output.write_text(json.dumps({"traceEvents": events}, indent=2) + "\n", encoding="utf-8")
    output.chmod(0o600)
    print(f"wrote {len(events)} events to {output}")
    return 0


if __name__ == "__main__":
    sys.exit(main())
