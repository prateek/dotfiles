#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""Serve a local trace file and open it in ui.perfetto.dev."""

from __future__ import annotations

import argparse
import functools
import http.server
import shutil
import socketserver
import sys
import tempfile
import threading
import time
import urllib.parse
import webbrowser
from pathlib import Path


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("trace", help="Perfetto trace JSON file")
    parser.add_argument("--port", type=int, default=0, help="Loopback HTTP port (default: random)")
    parser.add_argument("--idle-timeout", type=int, default=600, help="Seconds since last request before exit")
    parser.add_argument("--no-open", action="store_true", help="Print the URL without opening a browser")
    parser.add_argument("--print-url", action="store_true", help="Print the Perfetto URL")
    return parser.parse_args()


class TraceRequestHandler(http.server.SimpleHTTPRequestHandler):
    last_request_at = time.monotonic()
    allowed_origin = "https://ui.perfetto.dev"

    def end_headers(self) -> None:
        origin = self.headers.get("Origin")
        if origin == self.allowed_origin:
            self.send_header("Access-Control-Allow-Origin", self.allowed_origin)
            self.send_header("Access-Control-Allow-Methods", "GET, HEAD, OPTIONS")
            self.send_header("Access-Control-Allow-Headers", "Content-Type")
            self.send_header("Access-Control-Allow-Private-Network", "true")
        self.send_header("Cache-Control", "no-store")
        super().end_headers()

    def do_OPTIONS(self) -> None:
        TraceRequestHandler.last_request_at = time.monotonic()
        self.send_response(204)
        self.end_headers()

    def do_GET(self) -> None:
        TraceRequestHandler.last_request_at = time.monotonic()
        super().do_GET()

    def do_HEAD(self) -> None:
        TraceRequestHandler.last_request_at = time.monotonic()
        super().do_HEAD()

    def do_POST(self) -> None:
        TraceRequestHandler.last_request_at = time.monotonic()
        length = int(self.headers.get("Content-Length", "0") or "0")
        if length:
            self.rfile.read(length)
        self.send_response(204)
        self.end_headers()

    def log_message(self, format: str, *args: object) -> None:
        sys.stderr.write("open-perfetto: " + (format % args) + "\n")


class LoopbackServer(socketserver.TCPServer):
    allow_reuse_address = True


def main() -> int:
    args = parse_args()
    trace = Path(args.trace).expanduser().resolve()
    if not trace.is_file():
        print(f"open-perfetto: trace file not found: {trace}", file=sys.stderr)
        return 2

    serve_dir = Path(tempfile.mkdtemp(prefix="dotfiles-perfetto-"))
    try:
        served_trace = serve_dir / "trace.json"
        shutil.copyfile(trace, served_trace)

        handler = functools.partial(TraceRequestHandler, directory=str(serve_dir))
        try:
            server = LoopbackServer(("127.0.0.1", args.port), handler)
        except OSError as error:
            print(f"open-perfetto: could not bind 127.0.0.1:{args.port}: {error}", file=sys.stderr)
            return 2

        port = server.server_address[1]
        local_url = f"http://127.0.0.1:{port}/trace.json"
        perfetto_url = "https://ui.perfetto.dev/#!/?url=" + urllib.parse.quote(local_url, safe="")
        if args.print_url or args.no_open:
            print(perfetto_url, flush=True)
        if not args.no_open:
            webbrowser.open(perfetto_url)

        def idle_shutdown() -> None:
            while True:
                time.sleep(1)
                if time.monotonic() - TraceRequestHandler.last_request_at >= args.idle_timeout:
                    server.shutdown()
                    return

        threading.Thread(target=idle_shutdown, daemon=True).start()
        print(f"open-perfetto: serving {trace} on {local_url}", file=sys.stderr)
        print("open-perfetto: press Ctrl-C to stop", file=sys.stderr)
        try:
            server.serve_forever(poll_interval=0.5)
        except KeyboardInterrupt:
            pass
        finally:
            server.server_close()
    finally:
        shutil.rmtree(serve_dir, ignore_errors=True)

    return 0


if __name__ == "__main__":
    sys.exit(main())
