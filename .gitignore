### https://raw.github.com/github/gitignore/9f044c43d2fa998acb2d468367a349fff609dc84/Global/osx.gitignore
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon


# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

*.pyc
__pycache__/

# zsh compiled files
*.zwc
*.old
# SpecStory explanation file
.specstory/.what-is-this.md
.env
mise.local.toml
.mise.local.toml

*.bak

# Include local formatter dependencies
node_modules/
!home/dot_agents/packages/**/node_modules/
!home/dot_agents/packages/**/node_modules/**

# Apply-time generated agent projections
home/dot_agents/skills/
home/dot_agents/plugins/
home/dot_claude/skills/

# Codex system skills (installed automatically)
.codex/skills/.system/

# Hammerspoon build output
build/

# Tripwire: this repo doesn't use `ask`'s declarative mode. A stray `ask add`
# would scaffold `ask.json` and a subsequent `ask install` would clobber the
# curated AGENTS.md. Surface it as untracked so it doesn't get committed.
ask.json
